    StatPattern("retransmit_timeouts", re.compile(r"^retransmit timeout$")),
    StatPattern("sack_recovery_episodes", re.compile(r"^SACK recovery episode$")),
    StatPattern("rack_recovery_episodes", re.compile(r"^RACK recovery episode$")),
    StatPattern("probe_timeouts", re.compile(r"^probe timeout$")),
    StatPattern("reordering_detected", re.compile(r"^time packet reordering was detected")),
    StatPattern("open_sockets", re.compile(r"^open TCP sockets$")),
]


def parse_macos_tcp_stats(output: str) -> TcpStats:
    counters: dict[str, int] = {}
    for raw in output.splitlines():
        match = re.match(r"^\s*(\d+)\s+(.+?)\s*$", raw)
        if not match:
            continue
        value = int(match.group(1))
        label = re.sub(r"\s+", " ", match.group(2)).strip()
        for stat in STAT_PATTERNS:
            if stat.pattern.search(label):
                counters[stat.key] = value
                break
    return TcpStats(counters)


def parse_int(value: str) -> int:
    if value == "-":
        return 0
    return int(value)


def compute_views(
    snapshot: Snapshot,
    previous: Snapshot | None,
    first_seen: dict[ConnectionKey, float] | None = None,
    order: dict[ConnectionKey, int] | None = None,
) -> list[ConnectionView]:
    previous_by_key = {c.key: c for c in previous.connections} if previous else {}
    first_seen = first_seen or {}
    order = order or {}

    views: list[ConnectionView] = []
    for conn in snapshot.connections:
        prev = previous_by_key.get(conn.key)
        if prev:
            age_state = ""
        else:
            age_state = "new"
        views.append(
            ConnectionView(
                conn=conn,
                rx_rate=0.0,
                tx_rate=0.0,
                first_seen=first_seen.get(conn.key, snapshot.taken_at),
                order=order.get(conn.key, gencnt_order(conn)),
                age_state=age_state,
            )
        )
    return views


def compute_stat_rates(snapshot: Snapshot, previous: Snapshot | None) -> dict[str, float]:
    if not previous:
        return {}
    elapsed = max(0.001, snapshot.taken_at - previous.taken_at)
    rates: dict[str, float] = {}
    keys = set(snapshot.stats.counters) | set(previous.stats.counters)
    for key in keys:
        delta = snapshot.stats.get(key) - previous.stats.get(key)
        rates[key] = max(0, delta) / elapsed
    return rates


def gencnt_order(conn: TcpConnection) -> int:
    try:
        return int(conn.gencnt, 16)
    except ValueError:
        return 0


def fmt_bytes(value: float) -> str:
    units = ("B", "K", "M", "G", "T")
    size = float(value)
    for unit in units:
        if abs(size) < 1024.0 or unit == units[-1]:
            if unit == "B":
                return f"{size:.0f}{unit}"
            return f"{size:.1f}{unit}"
        size /= 1024.0
    return f"{size:.0f}B"


def fmt_optional_bytes(value: int | None) -> str:
    if value is None:
        return "-"
    return fmt_bytes(value)


def fit_right(value: str, width: int) -> str:
    return truncate(value, width).rjust(width)


def fmt_total_rate(total: int, rate: float) -> str:
    total_text = fit_right(fmt_bytes(total), TRANSFER_TOTAL_WIDTH)
    rate_text = fit_right(fmt_bytes(rate), TRANSFER_RATE_WIDTH)
    return f"{total_text} ({rate_text}/s)"


def fmt_count(value: int | None) -> str:
    if value is None:
        return "-"
    units = ("", "K", "M", "G")
    size = float(value)
    for unit in units:
        if abs(size) < 1000.0 or unit == units[-1]:
            return f"{size:.0f}{unit}" if unit == "" else f"{size:.1f}{unit}"
        size /= 1000.0
    return str(value)


def fmt_ms(value: float | None) -> str:
    if value is None:
        return "-"
    return f"{value:.0f}ms" if value >= 10 else f"{value:.1f}ms"


def truncate(value: str, width: int) -> str:
    if width <= 0:
        return ""
    if len(value) <= width:
        return value
    if width <= 3:
        return value[:width]
    return value[: width - 3] + "..."


def render_once(snapshot: Snapshot, previous: Snapshot | None = None, limit: int = 30) -> str:
    first_seen = {c.key: snapshot.taken_at for c in snapshot.connections}
    order = {c.key: gencnt_order(c) for c in snapshot.connections}
    views = compute_views(snapshot, previous, first_seen, order)
    views.sort(key=lambda v: (v.first_seen, v.order, v.conn.key), reverse=True)
    stat_rates = compute_stat_rates(snapshot, previous)
    counts = Counter(c.state for c in snapshot.connections)

    lines = [
        f"{snapshot.provider} {format_time(snapshot.taken_at)} "
        f"total={len(snapshot.connections)} established={counts['ESTABLISHED']} "
        f"listen={counts['LISTEN']} close_wait={counts['CLOSE_WAIT']}",
    ]
    if snapshot.errors:
        lines.extend(f"error: {err}" for err in snapshot.errors)
    lines.append(
        f"loss~=retrans_packets:{snapshot.stats.get('data_packets_retransmitted')} "
        f"retrans/s={stat_rates.get('data_packets_retransmitted', 0.0):.2f} "
        f"rto/s={stat_rates.get('retransmit_timeouts', 0.0):.2f} "
        f"ooo/s={stat_rates.get('out_of_order_packets', 0.0):.2f}"
    )
    lines.append(
        format_row(header_row(), width=10_000)
    )
    for view in views[:limit]:
        lines.append(format_row(display_row_for_view(view), width=10_000))
    return "\n".join(lines)


def run_tui(provider: TcpProvider, interval: float, include_all: bool) -> None:
    curses.wrapper(TuiApp(provider, interval, include_all).run)


class TuiApp:
    """Curses event loop and mutable runtime state for tcpview."""

    def __init__(self, provider: TcpProvider, interval: float, include_all: bool):
        self.provider = provider
        self.interval = interval
        self.show_all = include_all
        self.latest: Snapshot | None = None
        self.previous_for_delta: Snapshot | None = None
        self.slots = SlotTable()
        self.next_refresh = 0.0
        self.last_error = ""

    def run(self, stdscr: curses.window) -> None:
        self._configure_curses(stdscr)
        while True:
            now = time.monotonic()
            if now >= self.next_refresh:
                self.refresh(now)
            self.draw(stdscr)
            if self.handle_key(stdscr.getch(), stdscr):
                break

    def refresh(self, now: float) -> None:
        """Read provider data and merge it into the stable slot table."""
        try:
            self.previous_for_delta = self.latest
            self.latest = self.provider.snapshot()
            self.slots.update(
                self.latest,
                self.previous_for_delta,
                show_all=self.show_all,
                now=time.monotonic(),
                is_initial=self.previous_for_delta is None,
            )
        except Exception as exc:  # Defensive: keep the TUI alive.
            self.last_error = f"{type(exc).__name__}: {exc}"
        self.next_refresh = now + self.interval

    def draw(self, stdscr: curses.window) -> None:
        if self.latest:
            draw(stdscr, self.latest, self.previous_for_delta, self.slots, self.show_all, self.last_error)
        else:
            draw_empty(stdscr, self.provider.name, self.last_error)

    def handle_key(self, key: int, stdscr: curses.window) -> bool:
        if key in (ord("q"), ord("Q"), 27):
            return True
        if key in (ord("h"), ord("H")):
            open_help_pager(stdscr)
        elif key in (ord("a"), ord("A")):
            self.show_all = not self.show_all
        return False

    def _configure_curses(self, stdscr: curses.window) -> None:
        curses.curs_set(0)
        stdscr.nodelay(True)
        stdscr.timeout(100)
        if curses.has_colors():
            init_color_pairs()


def init_color_pairs() -> None:
    """Register color pairs used by cell and row highlight logic."""
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_GREEN, -1)
    curses.init_pair(2, curses.COLOR_YELLOW, -1)
    curses.init_pair(3, curses.COLOR_RED, -1)
    curses.init_pair(4, curses.COLOR_CYAN, -1)
    curses.init_pair(5, curses.COLOR_WHITE, -1)
    curses.init_pair(6, curses.COLOR_BLACK, curses.COLOR_CYAN)
    curses.init_pair(7, curses.COLOR_BLACK, curses.COLOR_GREEN)
    curses.init_pair(8, curses.COLOR_WHITE, curses.COLOR_RED)
    orange = 166 if curses.COLORS > 166 else curses.COLOR_YELLOW
    curses.init_pair(9, curses.COLOR_BLACK, orange)
    curses.init_pair(10, curses.COLOR_BLACK, curses.COLOR_YELLOW)
    curses.init_pair(11, orange, -1)


def should_slot_view(view: ConnectionView, show_all: bool) -> bool:
    return show_all or view.conn.state not in {"LISTEN", "TIME_WAIT"}


def update_slot_activity(slot: RowSlot, view: ConnectionView, now: float, is_new: bool) -> ConnectionView:
    rx_total = view.conn.rx_bytes
    tx_total = view.conn.tx_bytes
    retrans_total = view.conn.retransmits
    rx_dupe_total = view.conn.rx_dupe
    rx_ooo_total = view.conn.rx_ooo
    tx_win_value = view.conn.tx_win
    tx_cwin_value = view.conn.tx_cwin
    if is_new:
        slot.rx_total = rx_total
        slot.tx_total = tx_total
        slot.sampled_at = now
        slot.retrans_total = retrans_total
        slot.rx_dupe_total = rx_dupe_total
        slot.rx_ooo_total = rx_ooo_total
        slot.tx_win_value = tx_win_value
        slot.tx_cwin_value = tx_cwin_value
        slot.rx_highlight_until = 0.0
        slot.tx_highlight_until = 0.0
        slot.rx_soft_highlight_until = 0.0
        slot.tx_soft_highlight_until = 0.0
        slot.retrans_highlight_until = 0.0
        slot.retrans_soft_highlight_until = 0.0
        slot.rx_dupe_highlight_until = 0.0
        slot.rx_dupe_soft_highlight_until = 0.0
        slot.rx_ooo_highlight_until = 0.0
        slot.rx_ooo_soft_highlight_until = 0.0
        slot.tx_win_good_until = 0.0
        slot.tx_win_bad_until = 0.0
        slot.tx_win_soft_good_until = 0.0
        slot.tx_win_soft_bad_until = 0.0
        slot.tx_cwin_good_until = 0.0
        slot.tx_cwin_bad_until = 0.0
        slot.tx_cwin_soft_good_until = 0.0
        slot.tx_cwin_soft_bad_until = 0.0
        return replace(view, rx_rate=0.0, tx_rate=0.0)

    elapsed = max(0.001, now - slot.sampled_at) if slot.sampled_at else 0.001
    rx_delta = max(0, rx_total - slot.rx_total)
    tx_delta = max(0, tx_total - slot.tx_total)
    if rx_delta >= TRANSFER_HIGHLIGHT_DELTA_BYTES:
        slot.rx_highlight_until = now + TREND_HOLD_SECONDS
        slot.rx_soft_highlight_until = 0.0
    elif rx_delta > 0:
        slot.rx_soft_highlight_until = now + TREND_HOLD_SECONDS
    if tx_delta >= TRANSFER_HIGHLIGHT_DELTA_BYTES:
        slot.tx_highlight_until = now + TREND_HOLD_SECONDS
        slot.tx_soft_highlight_until = 0.0
    elif tx_delta > 0:
        slot.tx_soft_highlight_until = now + TREND_HOLD_SECONDS
    update_counter_trend(
        retrans_total,
        slot.retrans_total,
        RETRANS_STRONG_DELTA_BYTES,
        now,
        strong=lambda until: setattr(slot, "retrans_highlight_until", until),
        soft=lambda until: setattr(slot, "retrans_soft_highlight_until", until),
    )
    update_counter_trend(
        rx_dupe_total,
        slot.rx_dupe_total,
        DISORDER_STRONG_DELTA_COUNT,
        now,
        strong=lambda until: setattr(slot, "rx_dupe_highlight_until", until),
        soft=lambda until: setattr(slot, "rx_dupe_soft_highlight_until", until),
    )
    update_counter_trend(
        rx_ooo_total,
        slot.rx_ooo_total,
        DISORDER_STRONG_DELTA_COUNT,
        now,
        strong=lambda until: setattr(slot, "rx_ooo_highlight_until", until),
        soft=lambda until: setattr(slot, "rx_ooo_soft_highlight_until", until),
    )
    update_window_trend(slot, "tx_win", tx_win_value, now)
    update_window_trend(slot, "tx_cwin", tx_cwin_value, now)
    slot.rx_total = rx_total
    slot.tx_total = tx_total
    slot.sampled_at = now
    slot.retrans_total = retrans_total
    slot.rx_dupe_total = rx_dupe_total
    slot.rx_ooo_total = rx_ooo_total
    return replace(view, rx_rate=rx_delta / elapsed, tx_rate=tx_delta / elapsed)


def update_window_trend(slot: RowSlot, name: str, current: int | None, now: float) -> None:
    if name == "tx_win":
        previous = slot.tx_win_value
    else:
        previous = slot.tx_cwin_value

    if current is None:
        if name == "tx_win":
            slot.tx_win_value = None
            slot.tx_win_good_until = 0.0
            slot.tx_win_bad_until = 0.0
            slot.tx_win_soft_good_until = 0.0
            slot.tx_win_soft_bad_until = 0.0
        else:
            slot.tx_cwin_value = None
            slot.tx_cwin_good_until = 0.0
            slot.tx_cwin_bad_until = 0.0
            slot.tx_cwin_soft_good_until = 0.0
            slot.tx_cwin_soft_bad_until = 0.0
        return

    strong_good_until = 0.0
    strong_bad_until = 0.0
    soft_good_until = 0.0
    soft_bad_until = 0.0
    if current is not None and previous is not None:
        is_large = is_large_window_delta(current, previous)
        if current > previous:
            if is_large:
                strong_good_until = now + TREND_HOLD_SECONDS
            else:
                soft_good_until = now + TREND_HOLD_SECONDS
        elif current < previous:
            if is_large:
                strong_bad_until = now + TREND_HOLD_SECONDS
            else:
                soft_bad_until = now + TREND_HOLD_SECONDS

    if name == "tx_win":
        slot.tx_win_value = current
        if strong_good_until:
            slot.tx_win_good_until = strong_good_until
            slot.tx_win_bad_until = 0.0
            slot.tx_win_soft_good_until = 0.0
            slot.tx_win_soft_bad_until = 0.0
        elif strong_bad_until:
            slot.tx_win_bad_until = strong_bad_until
            slot.tx_win_good_until = 0.0
            slot.tx_win_soft_good_until = 0.0
            slot.tx_win_soft_bad_until = 0.0
        elif soft_good_until:
            slot.tx_win_soft_good_until = soft_good_until
            slot.tx_win_soft_bad_until = 0.0
        elif soft_bad_until:
            slot.tx_win_soft_bad_until = soft_bad_until
            slot.tx_win_soft_good_until = 0.0
    else:
        slot.tx_cwin_value = current
        if strong_good_until:
            slot.tx_cwin_good_until = strong_good_until
            slot.tx_cwin_bad_until = 0.0
            slot.tx_cwin_soft_good_until = 0.0
            slot.tx_cwin_soft_bad_until = 0.0
        elif strong_bad_until:
            slot.tx_cwin_bad_until = strong_bad_until
            slot.tx_cwin_good_until = 0.0
            slot.tx_cwin_soft_good_until = 0.0
            slot.tx_cwin_soft_bad_until = 0.0
        elif soft_good_until:
            slot.tx_cwin_soft_good_until = soft_good_until
            slot.tx_cwin_soft_bad_until = 0.0
        elif soft_bad_until:
            slot.tx_cwin_soft_bad_until = soft_bad_until
            slot.tx_cwin_soft_good_until = 0.0


def update_counter_trend(
    current: int | None,
    previous: int | None,
    strong_delta: int,
    now: float,
    strong: Callable[[float], None],
    soft: Callable[[float], None],
) -> None:
    if current is None or previous is None:
        return
    delta = current - previous
    if delta <= 0:
        return
    if delta >= strong_delta:
        strong(now + TREND_HOLD_SECONDS)
        soft(0.0)
    else:
        soft(now + TREND_HOLD_SECONDS)


def is_large_window_delta(current: int, previous: int) -> bool:
    delta = abs(current - previous)
    if delta >= WINDOW_STRONG_DELTA_BYTES:
        return True
    if previous <= 0:
        return delta > 0
    return delta / previous >= WINDOW_STRONG_DELTA_RATIO


def draw(
    stdscr: curses.window,
    snapshot: Snapshot,
    previous: Snapshot | None,
    slots: SlotTable,
    show_all: bool,
    last_error: str,
) -> None:
    height, width = stdscr.getmaxyx()
    stdscr.erase()

    stat_rates = compute_stat_rates(snapshot, previous)
    counts = Counter(c.state for c in snapshot.connections)

    title = (
        f"TCP quality {format_time(snapshot.taken_at)} "
        f"provider={snapshot.provider} "
        f"interval={interval_hint(snapshot, previous)}"
    )
    add(stdscr, 0, 0, truncate(title, width), curses.A_BOLD)

    summary = (
        f"total={len(snapshot.connections)} est={counts['ESTABLISHED']} "
        f"listen={counts['LISTEN']} close_wait={counts['CLOSE_WAIT']} "
        f"syn={counts['SYN_SENT'] + counts['SYN_RCVD']} "
        f"loss~=retrans_packets:{snapshot.stats.get('data_packets_retransmitted')} "
        f"retrans/s={stat_rates.get('data_packets_retransmitted', 0.0):.2f} "
        f"rto/s={stat_rates.get('retransmit_timeouts', 0.0):.2f} "
        f"ooo/s={stat_rates.get('out_of_order_packets', 0.0):.2f}"
    )
    add(stdscr, 1, 0, truncate(summary, width), curses.A_NORMAL)

    errors = list(snapshot.errors)
    if last_error:
        errors.append(last_error)
    if errors:
        add(stdscr, 2, 0, truncate("error: " + " | ".join(errors), width), curses.color_pair(3))
    else:
        now = time.monotonic()
        max_rows = visible_row_capacity(height)
        visible_slots = slots.visible_slots(max_rows, show_all, now)
        visible_count = slots.count_renderable(visible_slots, show_all, now)
        total_count = slots.count_renderable(slots.slots, show_all, now)
        overflow = max(0, total_count - visible_count)
        add(
            stdscr,
            2,
            0,
            truncate(
                f"mode={'all' if show_all else 'active'} rows={min(len(slots), max_rows)}/{len(slots)} "
                f"shown={visible_count}/{total_count} "
                f"overflow={overflow} "
                "keys: h help, q quit, a all",
                width,
            ),
            curses.color_pair(4),
        )

    header = format_row(header_row(), width)
    add(stdscr, 4, 0, header, curses.A_BOLD)

    now = time.monotonic()
    max_rows = visible_row_capacity(height)
    for idx, slot in enumerate(slots.visible_slots(max_rows, show_all, now), start=5):
        if not should_render_slot(slot, show_all, now):
            add(stdscr, idx, 0, "", curses.A_NORMAL)
            continue
        draw_connection_row(stdscr, idx, slot, width, now)

    stdscr.refresh()


def visible_row_capacity(height: int) -> int:
    return max(0, height - 5)


def should_render_slot(slot: RowSlot, show_all: bool, now: float) -> bool:
    view = slot.view
    if view is None:
        return False
    if slot.is_ended(now):
        return True
    return show_all or view.conn.state not in {"LISTEN", "TIME_WAIT"}


def draw_empty(stdscr: curses.window, provider_name: str, last_error: str) -> None:
    height, width = stdscr.getmaxyx()
    stdscr.erase()
    add(stdscr, 0, 0, truncate(f"TCP quality provider={provider_name}", width), curses.A_BOLD)
    message = last_error or "collecting..."
    add(stdscr, min(2, height - 1), 0, truncate(message, width), curses.color_pair(3))
    stdscr.refresh()


HELP_TEXT = """\
TCP quality TUI help
====================

This tool shows macOS TCP connection state using kernel netstat data enriched
with per-connection nettop metrics.  It is a diagnosis aid, not a speed test.
The most useful readings come from combinations of fields, trends, and whether
the connection is sending or receiving meaningful data.


Keys
----

  h       Open this help in less.
  a       Toggle active rows vs all rows. Active mode hides LISTEN/TIME_WAIT.
  q       Quit.
  Esc     Quit.


Row behavior
------------

Rows are stable slots.  Existing visible rows do not shift just because other
connections changed.  If a visible slot becomes empty, an offscreen displayable
connection may be moved into that empty slot.  Other visible rows are left in
place.

  cyan row       Newly observed connection.
  orange STATE   CLOSE_WAIT text.
  orange row     Any row during its final second before removal; STATE is ENDED.

If a row is going away for any reason, its background turns orange for one
second before the slot becomes reusable.  During that orange removal window the
STATE field is shown as ENDED.  New or offscreen connections prefer
reusable/empty rows near the top.


Fields
------

STATE
  TCP state.  ESTABLISHED is normal active TCP.  SYN_SENT means a connection is
  being opened.  CLOSE_WAIT means the peer closed but the local application has
  not closed its side yet; persistent CLOSE_WAIT is usually an application
  cleanup issue, not directly network quality.  ENDED is not a kernel state; it
  is a one-second TUI removal marker and should always appear with orange row
  background.

SVC
  Service guessed from destination TCP port, such as https, ssh, smtp, or the
  raw port number when unknown.  This is only a port-based guess.

RTT
  Average round-trip time from nettop.  It is the time scale at which TCP gets
  feedback from ACKs.  High RTT is not packet loss by itself, but it amplifies
  the cost of a small congestion window.  A rough throughput ceiling for a
  single sending TCP flow is:

      throughput ~= CWND / RTT

  Example: CWND 93KB and RTT 640ms is roughly 145KB/s.

RETRANS
  nettop re-tx.  Treat this as retransmitted data amount, effectively bytes,
  not a clean packet count.  It is one of the strongest quality warning signals.
  If RETRANS increases while CWND falls, the sender is likely reacting to
  loss/congestion.

RWND
  tx_win from nettop.  Receiver Window, the peer/receiver-side advertised send
  allowance: roughly how much the other side says it can receive from us.  If
  RWND is the smaller limit, the receiver or its application may be the
  bottleneck.

CWND
  tx_cwin from nettop.  Congestion Window, the congestion-control send
  allowance: how much unACKed data our TCP is willing to have in flight.  It
  reflects the sender's estimate of what the network path can tolerate.  It is
  useful mainly for traffic we are sending.  During mostly-receive traffic, CWND
  can be small without meaning the receive path is bad.

DUP
  rx_dupe from nettop.  Duplicate receive signal.  Nonzero or increasing values
  can indicate retransmission artifacts, ACK/loss side effects, reordering, or
  unstable paths.  It is a supporting signal, not a standalone verdict.

OOO
  rx_ooo from nettop.  Out-of-order receive signal.  Increasing OOO can point
  to path reordering, wireless/VPN/tunnel behavior, or multipath effects.  Some
  OOO can happen without user-visible trouble; watch it with RX, RTT, and
  RETRANS.

RX
  Receive total and receive rate computed from kernel rx byte counters.  The
  display is total plus current rate, for example 129M (500K/s).  This is the
  most direct throughput indicator when downloading/receiving data.

TX
  Send total and send rate computed from kernel tx byte counters.  The display
  is total plus current rate, for example 42M (1.2M/s).  This is the most
  direct throughput indicator when uploading/sending data.

PATH
  Interface plus congestion-control algorithm, for example en0/cubic or
  utun12/cubic.  utun often means VPN/tunnel.  en0 is usually Wi-Fi on macOS.

DESTINATION
  Remote endpoint.  For IPv6, netstat may truncate columns; this tool prefers
  the fuller endpoint from nettop when available.

PROCESS
  Process name and pid as reported by netstat/nettop.


Colors and trend indicators
---------------------------

  green cell
    A large useful/increasing signal.  RX/TX use green background when total
    bytes increased by at least 64KiB during one refresh.  RWND/CWND use green
    background when the window increased by at least 64KiB or 25%.

  green text
    A small useful/increasing signal.  RX/TX had a small positive byte delta,
    or RWND/CWND increased but did not cross the large-change threshold.

  red cell
    A large worsening signal.  RETRANS uses red background when retransmitted
    data increased by at least 64KiB during one refresh.  RWND/CWND use red
    background when the window decreased by at least 64KiB or 25%.

  red text
    A small worsening signal.  RETRANS increased but did not cross the
    large-change threshold, or RWND/CWND decreased by a small amount.  Very
    high RTT also uses red text because it is an absolute warning, not a delta.

  yellow cell
    A large receive-disorder signal.  DUP/OOO use yellow background when their
    counters increased by at least 10 during one refresh.

  yellow text
    Warning but not necessarily severe.  Moderate RTT may show yellow text.
    DUP/OOO also use yellow text for small positive counter deltas.

  orange STATE
    CLOSE_WAIT.  CLOSE_WAIT often points to local application behavior.

  orange row
    A row is about to be removed for any reason.  The full-row background is
    shown for one second before the slot becomes empty/reusable.  The STATE
    field is ENDED during this one-second removal window.

Trends are retained for a few seconds so short changes are visible.


Diagnosis guide
---------------

1. First decide direction.

   Mostly receiving:
     Focus on RX, RTT, RETRANS, DUP, and OOO.  CWND is sender-side and may
     not mean much if we are not sending data beyond ACK/control traffic.

   Mostly sending:
     Focus on TX, RTT, RETRANS, RWND, and CWND.  Sending throughput is
     bounded by receiver allowance, congestion-control allowance, and RTT.

2. Check actual throughput.

   RX or TX rate is the result that matters.  Window and RTT fields explain why
   the result may be high or low.

3. Interpret RWND vs CWND.

   RWND < CWND:
     The remote receiver/application may be limiting us.

   CWND < RWND:
     The network path/congestion-control side is the smaller limit.

   Both large, but TX rate low:
     The application may not be sending much, or another bottleneck exists.

   Both small:
     Could be a new/idle connection, receiver limitation, or poor network path.
     Use RTT and RETRANS to separate those cases.

4. Combine CWND and RTT for sending.

   A small CWND is not automatically bad.  It is bad relative to RTT and the
   throughput you expect.  Use:

       approximate single-flow send ceiling ~= CWND / RTT

   High RTT requires a larger CWND to achieve the same throughput.

5. Watch retransmission and reordering signals.

   RETRANS increasing:
     Strong sign of loss/congestion/retransmission behavior.

   DUP/OOO increasing:
     Supporting evidence of receive-side disorder, reordering, retransmission
     artifacts, or path instability.  More useful when paired with falling RX
     or rising RTT.

6. Interpret RTT carefully.

   High RTT can simply mean a distant endpoint, VPN, satellite/mobile path, or
   overloaded tunnel.  High RTT plus falling throughput and increasing RETRANS
   is much more suspicious than high RTT alone.


Common patterns
---------------

Good receive flow:
  RX rate stable or high, RETRANS not increasing, DUP/OOO quiet, RTT stable.

Bad receive flow:
  RX rate drops or oscillates, RETRANS increases, DUP/OOO increases, RTT jumps.

Good send flow:
  TX rate is near expected, CWND stable or rising, RWND is not the smaller
  bottleneck, RETRANS quiet.

Network/congestion-limited send:
  CWND < RWND, CWND falling or small relative to RTT, RETRANS increasing.

Receiver-limited send:
  RWND < CWND.  The peer or peer application is likely limiting receive
  capacity.

Application-limited:
  RWND and CWND both look sufficient, RTT is sane, RETRANS quiet, but RX or TX
  rate is low.  The application may simply not be moving data.

Local app cleanup issue:
  Persistent CLOSE_WAIT.  The remote closed; local process has not closed the
  socket.  This is usually not a raw network-quality problem.

VPN/tunnel path issue:
  PATH is utun*/cubic, RTT is high or unstable, DUP/OOO/RETRANS rise.  Compare
  with the same endpoint outside the VPN if possible.


Limitations
-----------

macOS does not expose all Linux ss -ti style TCP internals through netstat.
This tool uses what netstat and nettop expose.  Some fields are best understood
as practical signals, not exact protocol counters with perfect directionality.

RETRANS is treated as retransmitted data amount.  It is not a clean peer
retransmit packet count.  DUP and OOO are supporting receive-side signals, not
absolute proof of packet loss.
"""


def open_help_pager(stdscr: curses.window) -> None:
    curses.def_prog_mode()
    curses.endwin()
    try:
        subprocess.run(["less", "-R"], input=HELP_TEXT, text=True, check=False)
    finally:
        curses.reset_prog_mode()
        stdscr.clear()
        stdscr.refresh()


def interval_hint(snapshot: Snapshot, previous: Snapshot | None) -> str:
    if not previous:
        return "first"
    return f"{snapshot.taken_at - previous.taken_at:.1f}s"


def header_row() -> DisplayRow:
    return DisplayRow(
        state="STATE",
        svc="SVC",
        rtt="RTT",
        retrans="RETRANS",
        tx_win="RWND",
        tx_cwin="CWND",
        rx_dupe="DUP",
        rx_ooo="OOO",
        rx_rate="RX",
        tx_rate="TX",
        path="PATH",
        destination="DESTINATION",
        process="PROCESS",
    )


def display_row_for_view(view: ConnectionView) -> DisplayRow:
    c = view.conn
    destination = c.display_foreign or normalize_endpoint(c.foreign)
    return DisplayRow(
        state=display_state(c.state),
        svc=service_for_connection(c),
        rtt=fmt_ms(c.rtt_avg_ms),
        retrans=fmt_count(c.retransmits),
        tx_win=fmt_optional_bytes(c.tx_win),
        tx_cwin=fmt_optional_bytes(c.tx_cwin),
        rx_dupe=fmt_count(c.rx_dupe),
        rx_ooo=fmt_count(c.rx_ooo),
        rx_rate=fmt_total_rate(c.rx_bytes, view.rx_rate),
        tx_rate=fmt_total_rate(c.tx_bytes, view.tx_rate),
        path=truncate(path_label(c), 11),
        destination=truncate(destination, 28),
        process=truncate(process_label(c), 32),
    )


def display_state(state: str) -> str:
    normalized = state.upper()
    if normalized in {"FIN_WAIT_1", "FINWAIT1", "FIN_WAIT1"}:
        return "FIN_WAIT"
    return state


def display_row_for_slot(slot: RowSlot, now: float) -> DisplayRow:
    if slot.view is None:
        return header_row()
    row = display_row_for_view(slot.view)
    if slot.is_ended(now):
        return replace(row, state="ENDED")
    return row


def format_row(row: DisplayRow, width: int) -> str:
    if width >= 150:
        text = (
            f"{row.state:<13} {row.svc:<10} {row.rtt:>7} {row.retrans:>7} "
            f"{row.tx_win:>7} {row.tx_cwin:>7} "
            f"{row.rx_dupe:>6} {row.rx_ooo:>6} "
            f"{row.rx_rate:>{TRANSFER_CELL_WIDTH}} {row.tx_rate:>{TRANSFER_CELL_WIDTH}} "
            f"{row.path:<11} {row.destination:<24} {row.process}"
        )
    elif width >= 110:
        text = (
            f"{row.state:<12} {row.svc:<8} {row.rtt:>7} {row.retrans:>7} "
            f"{row.tx_win:>7} {row.tx_cwin:>7} "
            f"{row.rx_dupe:>5} {row.rx_ooo:>5} "
            f"{row.rx_rate:>{TRANSFER_CELL_WIDTH}} {row.tx_rate:>{TRANSFER_CELL_WIDTH}} "
            f"{row.path:<10} {row.destination:<18} {row.process}"
        )
    else:
        text = (
            f"{row.state:<10} {row.svc:<7} {row.rtt:>7} {row.retrans:>7} "
            f"{row.tx_cwin:>7} "
            f"{row.path:<9} {row.destination:<24} {row.process}"
        )
    return truncate(text, width)


def format_connection_row(view: ConnectionView, width: int) -> str:
    return format_row(display_row_for_view(view), width)


def draw_connection_row(stdscr: curses.window, y: int, slot: RowSlot, width: int, now: float) -> None:
    if slot.view is None:
        return
    row = format_row(display_row_for_slot(slot, now), width)
    base_attr = row_attr(slot, now)
    add(stdscr, y, 0, row.ljust(max(0, width - 1)), base_attr)
    if base_attr:
        return

    cells = connection_cells(slot, now)
    x = 0
    for cell in cells_for_width(cells, width):
        if cell.attr:
            add(stdscr, y, x, truncate(cell.render(), max(0, width - x)), cell.attr)
        x += cell.width + 1


def row_attr(slot: RowSlot, now: float) -> int:
    if slot.is_ended(now) and slot.ended_until - now <= ENDED_FLASH_SECONDS:
        return curses.color_pair(9)
    if slot.view and slot.view.age_state == "new":
        return curses.color_pair(6)
    return curses.A_NORMAL


def connection_cells(slot: RowSlot, now: float) -> list[Cell]:
    if slot.view is None:
        return []
    view = slot.view
    c = view.conn
    row = display_row_for_slot(slot, now)
    state = display_state(c.state)
    if slot.is_ended(now) or state == "CLOSE_WAIT":
        state_attr = curses.color_pair(11)
    elif state in {"SYN_SENT", "SYN_RCVD"}:
        state_attr = curses.color_pair(3)
    else:
        state_attr = 0
    rtt_attr = 0
    if c.rtt_avg_ms is not None:
        if not rtt_attr and c.rtt_avg_ms >= 250:
            rtt_attr = curses.color_pair(3)
        elif not rtt_attr and c.rtt_avg_ms >= 120:
            rtt_attr = curses.color_pair(2)
    retrans_attr = counter_attr(slot.retrans_highlight_until, slot.retrans_soft_highlight_until, now, 8, 3)
    rx_dupe_attr = counter_attr(slot.rx_dupe_highlight_until, slot.rx_dupe_soft_highlight_until, now, 10, 2)
    rx_ooo_attr = counter_attr(slot.rx_ooo_highlight_until, slot.rx_ooo_soft_highlight_until, now, 10, 2)
    tx_win_attr = trend_attr(
        slot.tx_win_good_until,
        slot.tx_win_bad_until,
        slot.tx_win_soft_good_until,
        slot.tx_win_soft_bad_until,
        now,
    )
    tx_cwin_attr = trend_attr(
        slot.tx_cwin_good_until,
        slot.tx_cwin_bad_until,
        slot.tx_cwin_soft_good_until,
        slot.tx_cwin_soft_bad_until,
        now,
    )
    rx_attr = transfer_attr(slot.rx_highlight_until, slot.rx_soft_highlight_until, now)
    tx_attr = transfer_attr(slot.tx_highlight_until, slot.tx_soft_highlight_until, now)

    return [
        Cell("state", row.state, 13, "<", state_attr),
        Cell("svc", row.svc, 10, "<"),
        Cell("rtt", row.rtt, 7, ">", rtt_attr),
        Cell("retrans", row.retrans, 7, ">", retrans_attr),
        Cell("tx_win", row.tx_win, 7, ">", tx_win_attr),
        Cell("tx_cwin", row.tx_cwin, 7, ">", tx_cwin_attr),
        Cell("rx_dupe", row.rx_dupe, 6, ">", rx_dupe_attr),
        Cell("rx_ooo", row.rx_ooo, 6, ">", rx_ooo_attr),
        Cell("rx", row.rx_rate, TRANSFER_CELL_WIDTH, ">", rx_attr),
        Cell("tx", row.tx_rate, TRANSFER_CELL_WIDTH, ">", tx_attr),
        Cell("path", row.path, 11, "<"),
        Cell("destination", row.destination, 24, "<"),
        Cell("process", row.process, 32, "<"),
    ]


def trend_attr(
    good_until: float,
    bad_until: float,
    soft_good_until: float,
    soft_bad_until: float,
    now: float,
) -> int:
    if now < bad_until:
        return curses.color_pair(8)
    if now < good_until:
        return curses.color_pair(7)
    if now < soft_bad_until:
        return curses.color_pair(3)
    if now < soft_good_until:
        return curses.color_pair(1)
    return 0


def transfer_attr(strong_until: float, soft_until: float, now: float) -> int:
    if now < strong_until:
        return curses.color_pair(7)
    if now < soft_until:
        return curses.color_pair(1)
    return 0


def counter_attr(strong_until: float, soft_until: float, now: float, strong_pair: int, soft_pair: int) -> int:
    if now < strong_until:
        return curses.color_pair(strong_pair)
    if now < soft_until:
        return curses.color_pair(soft_pair)
    return 0


def cells_for_width(cells: list[Cell], width: int) -> list[Cell]:
    if width >= 150:
        return cells
    if width >= 110:
        state, svc, rtt, retrans, tx_win, tx_cwin, rx_dupe, rx_ooo, rxs, txs, path, destination, proc = cells
        return [
            state.with_width(12),
            svc.with_width(8),
            rtt,
            retrans,
            tx_win,
            tx_cwin,
            rx_dupe.with_width(5),
            rx_ooo.with_width(5),
            rxs.with_width(TRANSFER_CELL_WIDTH),
            txs.with_width(TRANSFER_CELL_WIDTH),
            path.with_width(10),
            destination.with_width(18),
            proc,
        ]
    state, svc, rtt, retrans, _tx_win, tx_cwin, *_rest, path, destination, proc = cells
    return [
        state.with_width(10),
        svc.with_width(7),
        rtt,
        retrans,
        tx_cwin,
        path.with_width(9),
        destination.with_width(24),
        proc,
    ]


def path_label(conn: TcpConnection) -> str:
    if conn.interface and conn.cc_algo:
        return f"{conn.interface}/{conn.cc_algo}"
    return conn.interface or conn.cc_algo or "-"


def process_label(conn: TcpConnection) -> str:
    suffix = f":{conn.pid}" if conn.pid is not None else ""
    return f"{conn.process}{suffix or ':-'}"


def add(stdscr: curses.window, y: int, x: int, text: str, attr: int = 0) -> None:
    height, width = stdscr.getmaxyx()
    if y < 0 or y >= height or x >= width:
        return
    try:
        stdscr.addstr(y, x, text[: max(0, width - x - 1)], attr)
    except curses.error:
        pass


def format_time(timestamp: float) -> str:
    return dt.datetime.fromtimestamp(timestamp).strftime("%H:%M:%S")


def build_provider(args: argparse.Namespace) -> TcpProvider:
    system = platform.system()
    if system != "Darwin":
        raise SystemExit(f"this script currently supports macOS only; detected {system}")
    netstat = args.netstat or shutil.which("netstat") or "/usr/sbin/netstat"
    nettop = args.nettop or shutil.which("nettop") or "/usr/bin/nettop"
    return MacOSNetstatProvider(
        netstat=netstat,
        nettop=nettop,
        include_listeners=True,
        use_nettop=not args.no_nettop,
    )


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Realtime macOS TCP connection quality TUI using kernel netstat data."
    )
    parser.add_argument("-i", "--interval", type=float, default=1.0, help="refresh interval seconds")
    parser.add_argument("-n", "--limit", type=int, default=40, help="maximum rows to print with --once")
    parser.add_argument("--all", action="store_true", help="start by showing LISTEN/TIME_WAIT rows too")
    parser.add_argument("--once", action="store_true", help="print one snapshot and exit")
    parser.add_argument("--netstat", default="", help="path to netstat binary")
    parser.add_argument("--nettop", default="", help="path to nettop binary")
    parser.add_argument("--no-nettop", action="store_true", help="disable nettop RTT/retransmit enrichment")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    if args.interval <= 0:
        raise SystemExit("--interval must be positive")
    provider = build_provider(args)

    if args.once:
        snapshot = provider.snapshot()
        print(render_once(snapshot, limit=args.limit))
        return 1 if snapshot.errors else 0

    run_tui(provider, interval=args.interval, include_all=args.all)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
