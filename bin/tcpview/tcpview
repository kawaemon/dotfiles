class TcpProvider(Protocol):
    name: str

    def snapshot(self) -> Snapshot:
        ...


class MacOSNetstatProvider:
    name = "macos-netstat"

    def __init__(
        self,
        netstat: str = "netstat",
        nettop: str = "nettop",
        include_listeners: bool = True,
        use_nettop: bool = True,
    ):
        self.netstat = netstat
        self.nettop = nettop
        self.include_listeners = include_listeners
        self.use_nettop = use_nettop
        self.name = "macos-netstat+nettop" if use_nettop else "macos-netstat"

    def snapshot(self) -> Snapshot:
        errors: list[str] = []
        connections: list[TcpConnection] = []
        stats = TcpStats({})

        try:
            connections = self._read_connections()
        except ProviderError as exc:
            errors.append(str(exc))

        try:
            stats = self._read_stats()
        except ProviderError as exc:
            errors.append(str(exc))

        if self.use_nettop and connections:
            try:
                metrics = self._read_nettop_metrics()
                connections = merge_nettop_metrics(connections, metrics)
            except ProviderError as exc:
                errors.append(str(exc))

        if not self.include_listeners:
            connections = [c for c in connections if c.state != "LISTEN"]

        return Snapshot(
            provider=self.name,
            taken_at=time.time(),
            connections=connections,
            stats=stats,
            errors=tuple(errors),
        )

    def _run(self, args: list[str]) -> str:
        try:
            proc = subprocess.run(
                args,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=3.0,
                check=False,
            )
        except FileNotFoundError as exc:
            raise ProviderError(f"{args[0]} not found") from exc
        except subprocess.TimeoutExpired as exc:
            raise ProviderError(f"{' '.join(args)} timed out") from exc

        if proc.returncode != 0:
            err = proc.stderr.strip() or proc.stdout.strip() or "unknown error"
            raise ProviderError(f"{' '.join(args)} failed: {err}")
        return proc.stdout

    def _read_connections(self) -> list[TcpConnection]:
        output = self._run([self.netstat, "-anv", "-p", "tcp"])
        if not output.strip():
            raise ProviderError("netstat -anv -p tcp returned no output")
        return list(parse_macos_netstat_connections(output))

    def _read_stats(self) -> TcpStats:
        output = self._run([self.netstat, "-s", "-p", "tcp"])
        if not output.strip():
            raise ProviderError("netstat -s -p tcp returned no output")
        return parse_macos_tcp_stats(output)

    def _read_nettop_metrics(self) -> dict[TransportKey, NetTopMetrics]:
        output = self._run([self.nettop, "-m", "tcp", "-L", "1", "-n", "-x", "-j", "tx_cwin", "-s", "1"])
        if not output.strip():
            raise ProviderError("nettop returned no output")
        return parse_nettop_metrics(output)


class ProviderError(RuntimeError):
    pass


def parse_macos_netstat_connections(output: str) -> Iterable[TcpConnection]:
    for raw in output.splitlines():
        line = raw.rstrip()
        if not line.startswith(("tcp4", "tcp6")):
            continue

        parts = line.split()
        # Fixed prefix:
        # proto recvq sendq local foreign state rxbytes txbytes rhiwat shiwat
        # Fixed suffix:
        # tcp_state options gencnt flags flags1 usecnt rtncnt fltrs
        if len(parts) < 18:
            continue

        prefix = parts[:10]
        suffix = parts[-8:]
        process_text = " ".join(parts[10:-8]).strip()
        process = split_process_pid(process_text)

        try:
            yield TcpConnection(
                proto=prefix[0],
                recv_q=parse_int(prefix[1]),
                send_q=parse_int(prefix[2]),
                local=prefix[3],
                foreign=prefix[4],
                state=prefix[5],
                rx_bytes=parse_int(prefix[6]),
                tx_bytes=parse_int(prefix[7]),
                recv_hiwater=parse_int(prefix[8]),
                send_hiwater=parse_int(prefix[9]),
                process=process.name,
                pid=process.pid,
                kernel_state=suffix[0],
                options=suffix[1],
                gencnt=suffix[2],
                flags=suffix[3],
                flags1=suffix[4],
            )
        except ValueError:
            continue


def split_process_pid(value: str) -> ProcessInfo:
    if not value:
        return ProcessInfo("-", None)
    if ":" not in value:
        return ProcessInfo(value, None)
    name, pid_text = value.rsplit(":", 1)
    try:
        return ProcessInfo(name.strip() or "-", int(pid_text))
    except ValueError:
        return ProcessInfo(value, None)


def parse_nettop_metrics(output: str) -> dict[TransportKey, NetTopMetrics]:
    rows = csv.reader(output.splitlines())
    try:
        header = next(rows)
    except StopIteration:
        return {}

    indexes = {name: idx for idx, name in enumerate(header) if name}
    subject_idx = next((idx for idx, name in enumerate(header) if name == ""), 1)
    metrics: dict[TransportKey, NetTopMetrics] = {}
    current_process = ""
    current_pid: int | None = None

    for row in rows:
        if len(row) <= subject_idx:
            continue
        subject = row[subject_idx].strip()
        if not subject.startswith(("tcp4 ", "tcp6 ")):
            process = split_nettop_process_pid(subject)
            if process.pid is not None:
                current_process = process.name
                current_pid = process.pid
            continue

        key = parse_nettop_subject_key(subject)
        if not key:
            continue

        metrics[key] = NetTopMetrics(
            process=current_process,
            pid=current_pid,
            local=key.local,
            foreign=key.foreign,
            interface=csv_get(row, indexes, "interface"),
            rtt_avg_ms=parse_ms(csv_get(row, indexes, "rtt_avg")),
            rx_dupe=parse_optional_int(csv_get(row, indexes, "rx_dupe")),
            rx_ooo=parse_optional_int(csv_get(row, indexes, "rx_ooo")),
            retransmits=parse_optional_int(csv_get(row, indexes, "re-tx")),
            tx_win=parse_optional_int(csv_get(row, indexes, "tx_win")),
            tx_cwin=parse_optional_int(csv_get(row, indexes, "tx_cwin")),
            cc_algo=csv_get(row, indexes, "cc_algo"),
        )
    return metrics


def split_nettop_process_pid(value: str) -> ProcessInfo:
    if "." not in value:
        return ProcessInfo(value, None)
    name, pid_text = value.rsplit(".", 1)
    try:
        return ProcessInfo(name.strip() or "-", int(pid_text))
    except ValueError:
        return ProcessInfo(value, None)


def parse_nettop_subject_key(subject: str) -> TransportKey | None:
    proto, _, endpoints = subject.partition(" ")
    local, sep, foreign = endpoints.partition("<->")
    if not sep:
        return None
    return TransportKey(proto, normalize_endpoint(local), normalize_endpoint(foreign))


def merge_nettop_metrics(
    connections: list[TcpConnection],
    metrics: dict[TransportKey, NetTopMetrics],
) -> list[TcpConnection]:
    fallback = build_nettop_fallback_index(metrics)
    merged: list[TcpConnection] = []
    for conn in connections:
        metric = metrics.get(conn.transport_key)
        if not metric:
            metric = fallback.get(connection_fallback_key(conn))
        if not metric:
            merged.append(conn)
            continue
        merged.append(
            replace(
                conn,
                display_local=metric.local,
                display_foreign=metric.foreign,
                interface=metric.interface,
                rtt_avg_ms=metric.rtt_avg_ms,
                rx_dupe=metric.rx_dupe,
                rx_ooo=metric.rx_ooo,
                retransmits=metric.retransmits,
                tx_win=metric.tx_win,
                tx_cwin=metric.tx_cwin,
                cc_algo=metric.cc_algo,
            )
        )
    return merged


def build_nettop_fallback_index(
    metrics: dict[TransportKey, NetTopMetrics],
) -> dict[FallbackKey, NetTopMetrics]:
    index: dict[FallbackKey, NetTopMetrics] = {}
    for key, metric in metrics.items():
        fallback = FallbackKey(
            key.proto,
            endpoint_port(key.local),
            endpoint_port(key.foreign),
            metric.pid,
        )
        if metric.pid is not None:
            index[fallback] = metric
    return index


def connection_fallback_key(conn: TcpConnection) -> FallbackKey:
    return FallbackKey(
        conn.proto,
        endpoint_port(conn.local),
        endpoint_port(conn.foreign),
        conn.pid,
    )


def csv_get(row: list[str], indexes: dict[str, int], name: str) -> str:
    idx = indexes.get(name)
    if idx is None or idx >= len(row):
        return ""
    return row[idx].strip()


def parse_ms(value: str) -> float | None:
    if not value:
        return None
    match = re.match(r"^([0-9.]+)\s*ms$", value.strip())
    if not match:
        return None
    return float(match.group(1))


def parse_optional_int(value: str) -> int | None:
    if not value:
        return None
    try:
        return int(value)
    except ValueError:
        return None


def normalize_endpoint(endpoint: str) -> str:
    endpoint = endpoint.strip()
    if endpoint in {"*.*", "*:*", "*"}:
        return "*:*"

    if endpoint.count(":") == 1 and "." in endpoint.split(":", 1)[0]:
        host, port = endpoint.rsplit(":", 1)
        return f"{host}:{port}"

    if "." in endpoint:
        host, port = endpoint.rsplit(".", 1)
        if port == "*":
            return f"{host}:*"
        if port.isdigit():
            return f"{host}:{port}"

    return endpoint


def endpoint_port(endpoint: str) -> int | None:
    normalized = normalize_endpoint(endpoint)
    if normalized.endswith(":*") or ":" not in normalized:
        return None
    _, port_text = normalized.rsplit(":", 1)
    try:
        return int(port_text)
    except ValueError:
        return None


