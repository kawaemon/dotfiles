@dataclass
class RowSlot:
    """Stable screen row state for a single connection lifecycle.

    A slot may keep a disappeared connection for a short removal window so the
    row can flash before becoming reusable.  New connections reuse empty slots
    instead of shifting unrelated visible rows.
    """

    key: ConnectionKey | None = None
    view: ConnectionView | None = None
    rx_total: int = 0
    tx_total: int = 0
    sampled_at: float = 0.0
    retrans_total: int | None = None
    rx_dupe_total: int | None = None
    rx_ooo_total: int | None = None
    rx_highlight_until: float = 0.0
    tx_highlight_until: float = 0.0
    rx_soft_highlight_until: float = 0.0
    tx_soft_highlight_until: float = 0.0
    retrans_highlight_until: float = 0.0
    retrans_soft_highlight_until: float = 0.0
    rx_dupe_highlight_until: float = 0.0
    rx_dupe_soft_highlight_until: float = 0.0
    rx_ooo_highlight_until: float = 0.0
    rx_ooo_soft_highlight_until: float = 0.0
    tx_win_value: int | None = None
    tx_win_good_until: float = 0.0
    tx_win_bad_until: float = 0.0
    tx_win_soft_good_until: float = 0.0
    tx_win_soft_bad_until: float = 0.0
    tx_cwin_value: int | None = None
    tx_cwin_good_until: float = 0.0
    tx_cwin_bad_until: float = 0.0
    tx_cwin_soft_good_until: float = 0.0
    tx_cwin_soft_bad_until: float = 0.0
    ended_until: float = 0.0

    def is_ended(self, now: float) -> bool:
        return self.view is not None and self.ended_until > now

    def is_reusable(self, now: float) -> bool:
        return self.view is None or (self.ended_until > 0 and now >= self.ended_until)

    def clear(self) -> None:
        self.key = None
        self.view = None
        self.rx_total = 0
        self.tx_total = 0
        self.sampled_at = 0.0
        self.retrans_total = None
        self.rx_dupe_total = None
        self.rx_ooo_total = None
        self.rx_highlight_until = 0.0
        self.tx_highlight_until = 0.0
        self.rx_soft_highlight_until = 0.0
        self.tx_soft_highlight_until = 0.0
        self.retrans_highlight_until = 0.0
        self.retrans_soft_highlight_until = 0.0
        self.rx_dupe_highlight_until = 0.0
        self.rx_dupe_soft_highlight_until = 0.0
        self.rx_ooo_highlight_until = 0.0
        self.rx_ooo_soft_highlight_until = 0.0
        self.tx_win_value = None
        self.tx_win_good_until = 0.0
        self.tx_win_bad_until = 0.0
        self.tx_win_soft_good_until = 0.0
        self.tx_win_soft_bad_until = 0.0
        self.tx_cwin_value = None
        self.tx_cwin_good_until = 0.0
        self.tx_cwin_bad_until = 0.0
        self.tx_cwin_soft_good_until = 0.0
        self.tx_cwin_soft_bad_until = 0.0
        self.ended_until = 0.0

    def begin_removal(self, now: float, hold_seconds: float) -> None:
        """Start the row-removal window, or clear it if the window has expired."""
        if self.view is None:
            self.clear()
            return
        if self.ended_until > 0 and now >= self.ended_until:
            self.clear()
            return
        if self.ended_until <= 0:
            self.ended_until = now + hold_seconds


@dataclass
class SlotTable:
    """Owns fixed row-slot placement and per-connection trend state."""

    slots: list[RowSlot] = field(default_factory=list)
    first_seen: dict[ConnectionKey, float] = field(default_factory=dict)
    order: dict[ConnectionKey, int] = field(default_factory=dict)
    next_order: int = 1

    def __len__(self) -> int:
        return len(self.slots)

    def update(
        self,
        snapshot: Snapshot,
        previous: Snapshot | None,
        show_all: bool,
        now: float,
        is_initial: bool,
    ) -> None:
        """Merge a snapshot into stable slots without shifting unrelated rows."""
        self._update_connection_order(snapshot)
        all_views = compute_views(snapshot, previous, self.first_seen, self.order)
        hidden_keys = {view.conn.key for view in all_views if not should_slot_view(view, show_all)}
        views = [view for view in all_views if should_slot_view(view, show_all)]
        if is_initial:
            views = [replace(view, age_state="") for view in views]
        views_by_key = {view.conn.key: view for view in views}
        active_keys = set(views_by_key)

        for slot in self.slots:
            if slot.key in active_keys:
                view = views_by_key.pop(slot.key)  # type: ignore[arg-type]
                slot.view = update_slot_activity(slot, view, now, is_new=False)
                slot.ended_until = 0.0
            else:
                if slot.key in hidden_keys:
                    slot.begin_removal(now, ENDED_FLASH_SECONDS)
                elif slot.view is not None and slot.ended_until <= 0:
                    slot.begin_removal(now, ENDED_FLASH_SECONDS)
                elif slot.ended_until > 0 and now >= slot.ended_until:
                    slot.clear()

        self._place_new_views(views_by_key.values(), now)

    def fill_visible_holes(self, max_rows: int, show_all: bool, now: float) -> None:
        """Move offscreen renderable rows into visible holes only."""
        self.clear_expired(now)
        if max_rows <= 0:
            return

        donor_start = min(max_rows, len(self.slots))
        for target_idx in range(min(max_rows, len(self.slots))):
            if not self.is_hole(target_idx, show_all, now):
                continue
            donor_idx = self.find_offscreen_donor(donor_start, show_all, now)
            if donor_idx is None:
                continue
            self.move_slot(donor_idx, target_idx)

    def visible_slots(self, max_rows: int, show_all: bool, now: float) -> list[RowSlot]:
        self.fill_visible_holes(max_rows, show_all, now)
        return self.slots[:max_rows]

    def count_renderable(self, slots: Iterable[RowSlot], show_all: bool, now: float) -> int:
        return sum(1 for slot in slots if should_render_slot(slot, show_all, now))

    def clear_expired(self, now: float) -> None:
        for slot in self.slots:
            if slot.ended_until > 0 and now >= slot.ended_until:
                slot.clear()

    def is_hole(self, index: int, show_all: bool, now: float) -> bool:
        return not should_render_slot(self.slots[index], show_all, now)

    def find_offscreen_donor(self, start: int, show_all: bool, now: float) -> int | None:
        for idx in range(start, len(self.slots)):
            if should_render_slot(self.slots[idx], show_all, now):
                return idx
        return None

    def move_slot(self, source_idx: int, target_idx: int) -> None:
        self.slots[target_idx].clear()
        self.slots[target_idx], self.slots[source_idx] = self.slots[source_idx], self.slots[target_idx]

    def _update_connection_order(self, snapshot: Snapshot) -> None:
        for conn in snapshot.connections:
            if conn.key in self.first_seen:
                continue
            self.first_seen[conn.key] = snapshot.taken_at
            kernel_order = gencnt_order(conn)
            self.order[conn.key] = kernel_order if kernel_order else self.next_order
            self.next_order += 1

    def _place_new_views(self, views: Iterable[ConnectionView], now: float) -> None:
        new_views = sorted(views, key=lambda v: (v.first_seen, v.order, v.conn.key), reverse=True)
        for view in new_views:
            empty = next((slot for slot in self.slots if slot.is_reusable(now)), None)
            if empty is None:
                slot = RowSlot(key=view.conn.key, view=view)
                slot.view = update_slot_activity(slot, view, now, is_new=True)
                self.slots.append(slot)
            else:
                empty.clear()
                empty.key = view.conn.key
                empty.view = update_slot_activity(empty, view, now, is_new=True)


