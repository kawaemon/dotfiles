@dataclass
class AsyncJobs:
    executor: Executor
    callbacks: dict[Future[Any], Callable[[Any], None]] = field(default_factory=dict)

    def submit(self, func: Callable[..., Any], *args: Any, apply: Callable[[Any], None]) -> None:
        self.callbacks[self.executor.submit(func, *args)] = apply

    def apply_done(self) -> None:
        for future in [f for f in self.callbacks if f.done()]:
            self.callbacks.pop(future)(future.result())

    def __bool__(self) -> bool:
        return bool(self.callbacks)


