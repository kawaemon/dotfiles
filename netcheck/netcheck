def fetch_pub_ip(family: Family) -> tuple[Family, str]:
    host = "1.1.1.1" if family == Family.V4 else "[2606:4700:4700::1111]"
    url = f"http://{host}/cdn-cgi/trace"
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=2.0) as res:
            text = res.read().decode("utf-8")
            for line in text.splitlines():
                if line.startswith("ip="):
                    return family, line.split("=", 1)[1].strip()
    except Exception:
        pass
    return family, ""


@dataclass(frozen=True)
class RdapInfo:
    handle: str = ""
    name: str = ""
    country: str = ""
    registrant: str = ""
    error: str = ""

    @property
    def label(self) -> str:
        skip_words = {
            "Japan Network Information Center",
            "Asia Pacific Network Information Centre",
            "Internet Assigned Numbers Authority",
        }
        candidates = []
        for p in (self.name, self.registrant, self.country):
            if p and not any(w in p for w in skip_words):
                candidates.append(p)

        if candidates:
            if len(candidates) > 1 and candidates[0].upper().startswith(("NET-", "NET6-", "V6NET-", "IPV6-")):
                return candidates[1]
            return candidates[0]

        return self.name or self.registrant or self.handle


@dataclass
class HopStats:
    index: int
    family: Family
    ip: str = ""
    sent: int = 0
    recv: int = 0
    last_ms: float | None = None
    best_ms: float | None = None
    worst_ms: float | None = None
    total_ms: float = 0.0
    asn: str = ""
    as_name: str = ""
    pending: set[str] | None = None
    rdns: str | None = None  # None=pending, ""=not found/private, else=hostname

    @property
    def avg_ms(self) -> float | None:
        if not self.recv:
            return None
        return self.total_ms / self.recv

    @property
    def loss_pct(self) -> float | None:
        if not self.sent:
            return None
        return (self.sent - self.recv) * 100.0 / self.sent

    def note_reply(self, usec: int) -> None:
        ms = usec / 1000.0
        self.sent += 1
        self.recv += 1
        self.last_ms = ms
        self.best_ms = ms if self.best_ms is None else min(self.best_ms, ms)
        self.worst_ms = ms if self.worst_ms is None else max(self.worst_ms, ms)
        self.total_ms += ms

    def note_probe(self, seq: str) -> None:
        if self.pending is None:
            self.pending = set()
        self.pending.add(seq)

    def note_losses(self) -> None:
        if not self.pending:
            return
        self.sent += len(self.pending)
        self.pending.clear()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run mtr to a target and summarize packet loss, transit ASNs, and AS path.",
    )
    parser.add_argument("target", nargs="?", default=DEFAULT_TARGET)
    parser.add_argument("-c", "--count", type=int, default=None, help="mtr probe count")
    parser.add_argument("-i", "--interval", type=float, default=None, help="mtr probe interval seconds")
    parser.add_argument("-n", "--no-rdap", action="store_true", help="skip RDAP lookups")
    parser.add_argument("--tcp-port", type=int, default=443, help="TCP probe port")
    parser.add_argument("--udp-port", type=int, default=50000, help="UDP probe port")
    parser.add_argument(
        "--sudo",
        choices=("auto", "always", "never"),
        default="auto",
        help="use sudo for mtr; auto uses sudo on macOS when not already root",
    )
    parser.add_argument("--color", choices=("auto", "always", "never"), default="auto")
    args = parser.parse_args()

    privileged_mtr = os.geteuid() == 0 or _use_sudo_for_mtr(args)
    if args.count is None:
        args.count = 20 if privileged_mtr else 10
    if args.interval is None:
        args.interval = 0.2 if privileged_mtr else 1.0
    return args


def _use_sudo_for_mtr(args: argparse.Namespace) -> bool:
    if os.geteuid() == 0 or args.sudo == "never":
        return False
    return args.sudo == "always" or sys.platform == "darwin"


def _mtr_path() -> str:
    mtr = shutil.which("mtr")
    if not mtr:
        raise RuntimeError("mtr command not found")
    return mtr


def _sudo_path() -> str:
    sudo = shutil.which("sudo")
    if not sudo:
        raise RuntimeError("sudo command not found; rerun as root or pass --sudo never")
    return sudo


def _mtr_command_prefix(args: argparse.Namespace) -> list[str]:
    mtr = _mtr_path()
    if not _use_sudo_for_mtr(args):
        return [mtr]

    sudo = _sudo_path()
    proc = subprocess.run([sudo, "-v"], check=False)
    if proc.returncode != 0:
        raise RuntimeError("sudo authentication failed; rerun as root or pass --sudo never")
    return [sudo, "-n", mtr]


def _build_mtr_cmd(prefix: list[str], args: argparse.Namespace, *mode_flags: str) -> list[str]:
    return [
        *prefix,
        *mode_flags,
        "-n",
        "-c",
        str(args.count),
        "-i",
        str(args.interval),
        "-G",
        "0.5",
        "-m",
        "30",
        args.target,
    ]


def rdap_get(kind: str, value: str, timeout: float = 2.0) -> RdapInfo:
    url = f"{RDAP_BASE}/{kind}/{value}"
    req = urllib.request.Request(
        url,
        headers={
            "Accept": "application/rdap+json, application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as res:
            data = json.load(res)
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError) as exc:
        return RdapInfo(error=str(exc))

    return RdapInfo(
        handle=str(data.get("handle") or ""),
        name=str(data.get("name") or ""),
        country=str(data.get("country") or ""),
        registrant=entity_name(data.get("entities", []), {"technical", "administrative", "abuse", "registrant"}),
    )


def infer_asn_from_allocation(label: str) -> str:
    lowered = label.lower()
    for patterns, asn in KNOWN_ALLOCATION_ASNS:
        if any(pattern in lowered for pattern in patterns):
            return asn
    return ""


def allocation_lookup(ip: str, no_rdap: bool) -> tuple[str, str]:
    if no_rdap:
        return "", ""
    info = rdap_get("ip", ip)
    label = info.label
    asn = infer_asn_from_allocation(label)
    if asn:
        return asn, KNOWN_ASNS.get(asn, label)
    return "", label


def entity_name(entities: Any, preferred_roles: set[str]) -> str:
    if not isinstance(entities, list):
        return ""
    fallback = ""
    for entity in entities:
        if not isinstance(entity, dict):
            continue
        name = vcard_name(entity.get("vcardArray"))
        if name and not fallback:
            fallback = name
        roles = set(entity.get("roles") or [])
        if name and roles & preferred_roles:
            return name

        # Fallback to sub-entities if a name hasn't been found
        sub_name = entity_name(entity.get("entities", []), preferred_roles)
        if sub_name:
            if not fallback:
                fallback = sub_name
            if roles & preferred_roles:
                return sub_name

    return fallback


def vcard_name(vcard: Any) -> str:
    if not (isinstance(vcard, list) and len(vcard) == 2 and isinstance(vcard[1], list)):
        return ""
    for item in vcard[1]:
        if not (isinstance(item, list) and len(item) >= 4):
            continue
        if item[0] in {"fn", "org"} and item[3]:
            value = item[3]
            if isinstance(value, list):
                return " ".join(str(v) for v in value if v)
            return str(value)
    return ""


def run_text(cmd: list[str], timeout: float = 1.0) -> str:
    try:
        proc = subprocess.run(cmd, check=False, capture_output=True, text=True, timeout=timeout)
    except (OSError, subprocess.TimeoutExpired):
        return ""
    if proc.returncode != 0:
        return ""
    return proc.stdout


def add_unique(values: list[str], value: str) -> None:
    if value and value not in values:
        values.append(value)


def source_address(family: socket.AddressFamily, remote: tuple[Any, ...]) -> str:
    try:
        with socket.socket(family, socket.SOCK_DGRAM) as sock:
            sock.connect(remote)
            return str(sock.getsockname()[0])
    except OSError:
        return ""


def route_cmds() -> tuple[tuple[Family, list[str]], tuple[Family, list[str]]]:
    if sys.platform == "darwin":
        return (
            (Family.V4, ["route", "-n", "get", "default"]),
            (Family.V6, ["route", "-n", "get", "-inet6", "default"]),
        )
    return (
        (Family.V4, ["ip", "route", "show", "default"]),
        (Family.V6, ["ip", "-6", "route", "show", "default"]),
    )


def route_if_present(route: _Route) -> list[_Route]:
    return [route] if route.dev or route.them else []


def token_after(parts: list[str], token: str) -> str:
    try:
        idx = parts.index(token)
    except ValueError:
        return ""
    return parts[idx + 1] if idx + 1 < len(parts) else ""


def parse_darwin_default_route(family: Family, text: str) -> list[_Route]:
    route = _Route(family=family)
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("interface:"):
            route.dev = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("gateway:"):
            route.them = stripped.split(":", 1)[1].strip()
    return route_if_present(route)


def parse_linux_default_routes(family: Family, text: str) -> list[_Route]:
    routes: list[_Route] = []
    for line in text.splitlines():
        parts = line.split()
        route = _Route(
            family=family,
            dev=token_after(parts, "dev"),
            them=token_after(parts, "via"),
        )
        routes.extend(route_if_present(route))
    return routes


def default_routes() -> list[_Route]:
    routes: list[_Route] = []
    parser = parse_darwin_default_route if sys.platform == "darwin" else parse_linux_default_routes
    for family, cmd in route_cmds():
        routes.extend(parser(family, run_text(cmd)))
    return routes


def empty_addr_map() -> dict[Family, list[str]]:
    return {Family.V4: [], Family.V6: []}


def empty_gw_map() -> dict[Family, list[GwEntry]]:
    return {Family.V4: [], Family.V6: []}


def add_ip_addr_line(out: dict[Family, list[str]], line: str) -> None:
    parts = line.split()
    if "inet" in parts:
        add_unique(out[Family.V4], token_after(parts, "inet"))
    if "inet6" not in parts:
        return

    addr = token_after(parts, "inet6")
    if not addr.lower().startswith("fe80:"):
        add_unique(out[Family.V6], addr)


def netmask_prefix(parts: list[str]) -> str:
    mask = token_after(parts, "netmask")
    if not mask:
        return ""
    try:
        return f"/{int(mask, 16).bit_count()}"
    except ValueError:
        return ""


def ifconfig_prefix(parts: list[str]) -> str:
    prefix = token_after(parts, "prefixlen")
    return f"/{prefix}" if prefix else ""


def add_ifconfig_line(out: dict[Family, list[str]], line: str) -> None:
    parts = line.strip().split()
    if len(parts) < 2:
        return
    if parts[0] == "inet":
        add_unique(out[Family.V4], f"{parts[1]}{netmask_prefix(parts)}")
        return
    if parts[0] != "inet6":
        return

    addr = parts[1].split("%", 1)[0]
    if not addr.lower().startswith("fe80:"):
        add_unique(out[Family.V6], f"{addr}{ifconfig_prefix(parts)}")


def interface_addresses(dev: str) -> dict[Family, list[str]]:
    out = empty_addr_map()
    for line in run_text(["ip", "-o", "addr", "show", "dev", dev]).splitlines():
        add_ip_addr_line(out, line)
    for line in run_text(["ifconfig", dev]).splitlines():
        add_ifconfig_line(out, line)
    return out


def pick_us(addrs: list[str], source: str) -> str:
    for addr in addrs:
        if addr.split("/", 1)[0] == source:
            return addr
    return addrs[0] if addrs else source


def local_gateway_info() -> dict[Family, list[GwEntry]]:
    out = empty_gw_map()
    src = {
        Family.V4: source_address(socket.AF_INET, ("1.1.1.1", 53)),
        Family.V6: source_address(socket.AF_INET6, ("2606:4700:4700::1111", 53, 0, 0)),
    }
    routes = default_routes()
    if not routes:
        routes = [_Route(family=fam) for fam, s in src.items() if s]

    for route in routes:
        family = route.family
        addrs = interface_addresses(route.dev) if route.dev else empty_addr_map()
        out[family].append(GwEntry(
            dev=route.dev or "-",
            us=pick_us(addrs[family], src[family]) or "-",
            them=route.them or "-",
        ))
    return out


def is_global_ip(ip: str) -> bool:
    try:
        return ipaddress.ip_address(ip).is_global
    except ValueError:
        return False


def ip_special_purpose(ip: str) -> str:
    try:
        addr = ipaddress.ip_address(ip)
        if addr.is_global:
            return ""
        if addr.is_link_local:
            return "Link-Local"
        if addr.is_private:
            return "Unique Local (ULA)" if addr.version == 6 else "Private Use"
        if addr.is_loopback:
            return "Loopback"
        if addr.is_multicast:
            return "Multicast"
        if addr.is_reserved:
            return "Reserved"
        return "Non-Global"
    except ValueError:
        return ""


class Color:
    def __init__(self, enabled: bool) -> None:
        self.enabled = enabled

    def paint(self, text: str, code: str) -> str:
        if not self.enabled:
            return text
        return f"\033[{code}m{text}\033[0m"

    def dim(self, text: str) -> str:
        return self.paint(text, "2")

    def green(self, text: str) -> str:
        return self.paint(text, "32")

    def yellow(self, text: str) -> str:
        return self.paint(text, "33")

    def red(self, text: str) -> str:
        return self.paint(text, "31")

    def cyan(self, text: str) -> str:
        return self.paint(text, "36")

    def bold(self, text: str) -> str:
        return self.paint(text, "1")


def use_color(mode: str) -> bool:
    if mode == "always":
        return True
    if mode == "never" or os.environ.get("NO_COLOR"):
        return False
    return sys.stdout.isatty()


def color_loss(value: float | None, color: Color, width: int = 0) -> str:
    text = ("-" if value is None else f"{value:.1f}%").rjust(width)
    if value is None:
        return color.dim(text)
    if value >= 5:
        return color.red(text)
    if value > 0:
        return color.yellow(text)
    return color.green(text)


def color_latency(value: float | None, color: Color, width: int = 0) -> str:
    text = ("-" if value is None else f"{value:.1f}ms").rjust(width)
    if value is None:
        return color.dim(text)
    if value >= 150:
        return color.red(text)
    if value >= 50:
        return color.yellow(text)
    return text


def as_label(asn: str, name: str = "") -> str:
    if asn.startswith("AS"):
        asn = asn[2:]
    if asn and name:
        return f"AS{asn} - {name}"
    if asn:
        return f"AS{asn}"
    return name


def visible_hops(hops: dict[tuple[Family, int], HopStats]) -> dict[Family, list[HopStats]]:
    by_fam: dict[Family, list[HopStats]] = {}
    for fam, i in sorted(hops.keys(), key=lambda k: (k[0], k[1])):
        hop = hops[(fam, i)]
        fam_list = by_fam.setdefault(fam, [])
        if fam_list and hop.ip and hop.ip == fam_list[-1].ip:
            continue
        fam_list.append(hop)
    return by_fam


def reverse_dns(ip: str) -> str:
    try:
        hostname = socket.getnameinfo((ip, 0), 0)[0]
        return "" if hostname == ip else hostname
    except (socket.gaierror, OSError):
        return ""


def _resolve(host: str) -> dict[Family, str]:
    result: dict[Family, str] = {}
    for fam, sock_fam in ((Family.V4, socket.AF_INET), (Family.V6, socket.AF_INET6)):
        try:
            infos = socket.getaddrinfo(host, None, sock_fam, socket.SOCK_STREAM)
            if infos:
                addr = infos[0][4][0]
                # Skip IPv4-mapped IPv6 addresses (::ffff:x.x.x.x) returned for IPv4 literals
                if fam == Family.V6 and ipaddress.IPv6Address(addr).ipv4_mapped is not None:
                    continue
                result[fam] = addr
        except socket.gaierror:
            pass
    return result


def probe_icmp(addr: str, family: Family, timeout: float = 3.0) -> ProbeResult:
    if sys.platform == "darwin":
        # macOS: no -4/-6 flag; IPv6 needs ping6.
        # ping -W is milliseconds; ping6 has no timeout arg, rely on run_text timeout.
        if family == Family.V6:
            out = run_text(["ping6", "-c", "1", addr], timeout=timeout + 1)
        else:
            out = run_text(["ping", "-c", "1", "-W", str(int(timeout * 1000)), addr], timeout=timeout + 1)
    else:
        flag = "-6" if family == Family.V6 else "-4"
        out = run_text(["ping", flag, "-c", "1", "-W", str(int(timeout)), addr], timeout=timeout + 1)
    m = re.search(r"time[=<]([\d.]+)", out)
    if m:
        return ProbeResult(rtt_ms=float(m.group(1)), status="ok")
    return ProbeResult(rtt_ms=None)


def probe_tcp(addr: str, port: int, timeout: float = 3.0) -> ProbeResult:
    t0 = time.monotonic()
    try:
        with socket.create_connection((addr, port), timeout=timeout):
            pass
        return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
    except ConnectionRefusedError:
        return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
    except socket.timeout:
        return ProbeResult(rtt_ms=None)
    except OSError as exc:
        return ProbeResult(rtt_ms=None, status=type(exc).__name__)


def probe_udp(addr: str, family: Family, port: int, timeout: float = 3.0) -> ProbeResult:
    sock_fam = socket.AF_INET6 if family == Family.V6 else socket.AF_INET
    with socket.socket(sock_fam, socket.SOCK_DGRAM) as sock:
        sock.settimeout(timeout)
        # connect() is required for ICMP port-unreachable to surface as
        # ConnectionRefusedError on BSD/macOS; unconnected sendto() silently drops it.
        sock.connect((addr, port))
        try:
            t0 = time.monotonic()
            sock.send(b"netcheck")
            sock.recv(64)
            return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
        except ConnectionRefusedError:
            return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
        except socket.timeout:
            return ProbeResult(rtt_ms=None)
        except OSError as exc:
            return ProbeResult(rtt_ms=None, status=type(exc).__name__)


def _run_probe(key: ProbeKey, addr: str) -> ProbeResult:
    match key.proto:
        case Proto.ICMP:
            return probe_icmp(addr, key.family)
        case Proto.TCP:
            assert key.port is not None
            return probe_tcp(addr, key.port)
        case Proto.UDP:
            assert key.port is not None
            return probe_udp(addr, key.family, key.port)
        case _:
            raise ValueError(f"unknown proto: {key.proto}")


def _fmt_probe(result: ProbeResult | None, color: Color) -> str:
    if result is None:
        return color.dim("…")
    if result.rtt_ms is not None:
        return color.green(f"{result.rtt_ms:.1f}ms")
    return color.red(result.status)


def _format_as_alloc(hop: HopStats, color: Color, width: int = 0) -> str:
    text = get_as_alloc_str(hop) or "-"
    padded = text.ljust(width)
    return color.cyan(padded) if hop.asn else padded


def _rdns_display(hop: HopStats) -> str:
    if not hop.ip:
        return ""
    if hop.rdns is None:
        return "…"
    return hop.rdns or "-"


def get_as_alloc_str(hop: HopStats) -> str:
    if hop.asn or hop.as_name:
        return as_label(hop.asn, hop.as_name)
    if hop.ip:
        return ip_special_purpose(hop.ip)
    return ""


def pub_ip_text(info: PubIpInfo) -> str:
    return "…" if info.ip is None else (info.ip or "-")


def pub_rdns_text(info: PubIpInfo) -> str:
    if not info.ip:
        return ""
    rdns = "…" if info.rdns is None else (info.rdns or "-")
    return f" ({rdns})"


def nat_label(family: Family, entry: GwEntry, pub_ip: str, color: Color) -> str:
    us_ip = entry.us.split("/")[0] if entry.us != "-" else ""
    if not us_ip or us_ip == pub_ip:
        return ""
    if family == Family.V4:
        return color.yellow(" (NAT)")
    return color.yellow(f" ({v6_nat_kind(us_ip, pub_ip)})")


def v6_nat_kind(us_ip: str, pub_ip: str) -> str:
    try:
        us_v6 = ipaddress.IPv6Address(us_ip)
        pub_v6 = ipaddress.IPv6Address(pub_ip)
    except ValueError:
        return "NAT66"
    return "NPTv6" if us_v6.packed[8:] == pub_v6.packed[8:] else "NAT66"


def pub_line(family: Family, entries: list[GwEntry], info: PubIpInfo, color: Color) -> str:
    nat = nat_label(family, entries[0], info.ip, color) if info.ip and entries else ""
    return f"pub: {color.cyan(pub_ip_text(info))}{pub_rdns_text(info)}{nat}"


def print_gateway_block(gw: dict[Family, list[GwEntry]], pub_info: dict[Family, PubIpInfo], color: Color) -> None:
    print(f"{color.bold('gw')}:")
    for family in FAMILIES:
        entries = gw.get(family) or []
        pub_str = pub_line(family, entries, pub_info.get(family, PubIpInfo()), color)
        if not entries:
            print(f"  {family}: -")
            print(f"      {pub_str}")
            continue
        for i, entry in enumerate(entries):
            print(
                f"  {family}: "
                f"dev: {color.cyan(entry.dev)}, "
                f"us: {color.cyan(entry.us)}, "
                f"them: {color.cyan(entry.them)}"
            )
            if i == 0:
                print(f"      {pub_str}")


@dataclass(frozen=True)
class RenderWidths:
    ip: int
    as_alloc: int
    rdns: int


def render_widths(hops: list[HopStats]) -> RenderWidths:
    rdns = max((len(_rdns_display(hop)) for hop in hops if hop.ip), default=0)
    return RenderWidths(
        ip=max((len(hop.ip or "-") for hop in hops), default=15),
        as_alloc=max(max((len(get_as_alloc_str(hop)) for hop in hops if hop.ip), default=13), 13),
        rdns=max(rdns, 4) if rdns > 0 else 0,
    )


def group_probe_keys(probes: dict[ProbeKey, ProbeResult | None]) -> tuple[dict[str, list[ProbeKey]], list[Family]]:
    labels: dict[str, list[ProbeKey]] = {}
    fams: list[Family] = []
    for key in probes:
        labels.setdefault(key.label(), []).append(key)
        if key.family not in fams:
            fams.append(key.family)
    return labels, fams


def print_probe_block(probes: dict[ProbeKey, ProbeResult | None], color: Color) -> None:
    label_keys, fams = group_probe_keys(probes)
    label_w = max(len(label) for label in label_keys)
    print(f"{color.bold('probe')}:")
    for label, keys in label_keys.items():
        key_map = {key.family: key for key in keys}
        cols = "  ".join(
            f"{fam}: {_fmt_probe(probes.get(key_map[fam]), color)}"
            for fam in fams
            if fam in key_map
        )
        print(f"  {label.ljust(label_w)}  {cols}")


def trace_header(widths: RenderWidths) -> str:
    rdns = f" {'rdns'.ljust(widths.rdns)}" if widths.rdns > 0 else ""
    return f"{'hop':>3} {'loss':>7} {'snt':>4} {'best':>8} {'ip':<{widths.ip}} {'as/allocation':<{widths.as_alloc}}{rdns}"


def print_trace_row(hop: HopStats, widths: RenderWidths, color: Color) -> None:
    rdns_col = f" {_rdns_display(hop)}" if widths.rdns > 0 else ""
    print(
        f"{hop.index + 1:>3} "
        f"{color_loss(hop.loss_pct, color, 7)} "
        f"{hop.sent:>4} "
        f"{color_latency(hop.best_ms, color, 8)} "
        f"{color.cyan((hop.ip or '-').ljust(widths.ip))} "
        f"{_format_as_alloc(hop, color, widths.as_alloc)}"
        f"{rdns_col}"
    )


def print_trace_blocks(visible_by_fam: dict[Family, list[HopStats]], widths: RenderWidths, color: Color) -> None:
    header = trace_header(widths)
    for fam in FAMILIES:
        if fam not in visible_by_fam:
            continue
        print(color.bold(f"trace {fam}:"))
        print(header)
        for hop in visible_by_fam[fam]:
            print_trace_row(hop, widths, color)


def render_live(
    target: str,
    gw: dict[Family, list[GwEntry]],
    hops: dict[tuple[Family, int], HopStats],
    color: Color,
    *,
    clear: bool,
    done: bool = False,
    probes: dict[ProbeKey, ProbeResult | None] | None = None,
    pub_info: dict[Family, PubIpInfo] | None = None,
) -> None:
    visible_by_fam = visible_hops(hops)
    widths = render_widths([hop for fam_hops in visible_by_fam.values() for hop in fam_hops])
    if clear:
        print("\033[H\033[2J", end="")

    status = color.green("done") if done else color.yellow("running")
    print(f"{color.bold('target')}: {target}  {color.bold('status')}: {status}")
    print_gateway_block(gw, pub_info or {fam: PubIpInfo() for fam in FAMILIES}, color)
    if probes:
        print_probe_block(probes, color)
    print()
    print_trace_blocks(visible_by_fam, widths, color)
    sys.stdout.flush()


@dataclass
class TraceState:
    hops: dict[HopKey, HopStats] = field(default_factory=dict)
    probes: dict[ProbeKey, ProbeResult | None] = field(default_factory=dict)
    pub_info: dict[Family, PubIpInfo] = field(default_factory=lambda: {fam: PubIpInfo() for fam in FAMILIES})
    lookup_ips: set[str] = field(default_factory=set)
    ip_as_cache: dict[str, tuple[str, str]] = field(default_factory=dict)
    ip_rdns_cache: dict[str, str] = field(default_factory=dict)

    def apply_asn(self, ip: str, asn: str, as_name: str) -> None:
        self.ip_as_cache[ip] = (asn, as_name)
        for hop in self.hops.values():
            if hop.ip == ip:
                hop.asn = asn
                hop.as_name = as_name

    def apply_rdns(self, ip: str, hostname: str) -> None:
        self.ip_rdns_cache[ip] = hostname
        for hop in self.hops.values():
            if hop.ip == ip:
                hop.rdns = hostname


def probe_keys(args: argparse.Namespace, fam: Family) -> list[ProbeKey]:
    keys = [ProbeKey(Proto.ICMP, fam)]
    if args.tcp_port:
        keys.append(ProbeKey(Proto.TCP, fam, args.tcp_port))
    if args.udp_port:
        keys.append(ProbeKey(Proto.UDP, fam, args.udp_port))
    return keys


def start_public_ip_checks(state: TraceState, jobs: AsyncJobs) -> None:
    for fam in FAMILIES:
        jobs.submit(fetch_pub_ip, fam, apply=lambda result, fam=fam: apply_public_ip(state, jobs, fam, result[1]))


def apply_public_ip(state: TraceState, jobs: AsyncJobs, fam: Family, ip: str) -> None:
    state.pub_info[fam].ip = ip
    if not ip:
        state.pub_info[fam].rdns = ""
        return
    jobs.submit(reverse_dns, ip, apply=lambda hostname, fam=fam, ip=ip: apply_public_rdns(state, fam, ip, hostname))


def apply_public_rdns(state: TraceState, fam: Family, ip: str, hostname: str) -> None:
    if state.pub_info[fam].ip == ip:
        state.pub_info[fam].rdns = hostname


def start_probes(args: argparse.Namespace, state: TraceState, jobs: AsyncJobs, resolved: dict[Family, str]) -> None:
    for fam, addr in resolved.items():
        for key in probe_keys(args, fam):
            state.probes[key] = None
            jobs.submit(_run_probe, key, addr, apply=lambda result, key=key: state.probes.__setitem__(key, result))


def process_mtr_line(args: argparse.Namespace, state: TraceState, jobs: AsyncJobs, fam: Family, raw_line: str) -> None:
    parts = raw_line.strip().split()
    if len(parts) < 3:
        return

    try:
        index = int(parts[1])
    except ValueError:
        return

    key = (fam, index)
    hop = state.hops.setdefault(key, HopStats(index=index, family=fam))

    match parts[0]:
        case "x":
            hop.note_probe(parts[2])
        case "h":
            note_hop_ip(args, state, jobs, hop, parts[2])
        case "p":
            note_probe_reply(hop, parts)


def note_hop_ip(args: argparse.Namespace, state: TraceState, jobs: AsyncJobs, hop: HopStats, ip: str) -> None:
    hop.ip = ip
    if ip in state.ip_as_cache:
        hop.asn, hop.as_name = state.ip_as_cache[ip]
    if ip in state.ip_rdns_cache:
        hop.rdns = state.ip_rdns_cache[ip]
    elif is_global_ip(ip):
        hop.rdns = None
    else:
        hop.rdns = ""

    if not is_global_ip(ip) or ip in state.lookup_ips:
        return

    state.lookup_ips.add(ip)
    jobs.submit(
        allocation_lookup,
        ip,
        args.no_rdap,
        apply=lambda result, ip=ip: apply_allocation(state, ip, result),
    )
    jobs.submit(reverse_dns, ip, apply=lambda hostname, ip=ip: state.apply_rdns(ip, hostname))


def apply_allocation(state: TraceState, ip: str, result: tuple[str, str]) -> None:
    asn, as_name = result
    if asn or as_name:
        state.apply_asn(ip, asn, as_name)


def note_probe_reply(hop: HopStats, parts: list[str]) -> None:
    try:
        if hop.pending and len(parts) >= 4:
            hop.pending.discard(parts[3])
        hop.note_reply(int(parts[2]))
    except ValueError:
        pass


def _read_mtr_stdout(proc: subprocess.Popen[str], fam: Family, out: queue.Queue[tuple[Family, str] | object]) -> None:
    assert proc.stdout is not None
    for raw_line in proc.stdout:
        out.put((fam, raw_line))
    out.put(MTR_DONE)


def _start_mtr_processes(cmd: list[str], resolved: dict[Family, str], out: queue.Queue[tuple[Family, str] | object]) -> list[subprocess.Popen[str]]:
    procs: list[subprocess.Popen[str]] = []
    for fam, addr in resolved.items():
        fam_cmd = cmd.copy()
        fam_cmd[-1] = addr
        proc = subprocess.Popen(
            fam_cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        procs.append(proc)
        threading.Thread(target=_read_mtr_stdout, args=(proc, fam, out), daemon=True).start()
    return procs


def _finish_processes(procs: list[subprocess.Popen[str]]) -> None:
    for proc in procs:
        try:
            proc.wait(timeout=1)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=1)


def _mtr_return_status(procs: list[subprocess.Popen[str]]) -> tuple[int, str]:
    stderr = ""
    returncode = 0
    for proc in procs:
        if proc.stderr is not None:
            err = proc.stderr.read().strip()
            if err:
                stderr += f"{err}\n"
        if proc.returncode not in (0, -15):
            returncode = proc.returncode or 1
    return returncode, stderr


@dataclass
class LiveRun:
    args: argparse.Namespace
    color: Color
    executor: Executor
    state: TraceState = field(default_factory=TraceState)
    gw: dict[Family, list[GwEntry]] = field(default_factory=local_gateway_info)
    jobs: AsyncJobs = field(init=False)
    clear: bool = field(init=False)

    def __post_init__(self) -> None:
        self.jobs = AsyncJobs(self.executor)
        self.clear = self.color.enabled and sys.stdout.isatty()

    def start(self, resolved: dict[Family, str]) -> None:
        start_public_ip_checks(self.state, self.jobs)
        start_probes(self.args, self.state, self.jobs, resolved)

    def render(self, *, done: bool = False) -> None:
        render_live(
            self.args.target,
            self.gw,
            self.state.hops,
            self.color,
            clear=self.clear,
            done=done,
            probes=self.state.probes,
            pub_info=self.state.pub_info,
        )

    def handle_mtr_item(self, q: queue.Queue[tuple[Family, str] | object], active_procs: int) -> int:
        try:
            item = q.get(timeout=0.1)
        except queue.Empty:
            self.jobs.apply_done()
            return active_procs

        if item is MTR_DONE:
            self.jobs.apply_done()
            return active_procs - 1

        fam, raw_line = item
        process_mtr_line(self.args, self.state, self.jobs, fam, raw_line)
        self.jobs.apply_done()
        return active_procs

    def run_mtr(self, cmd: list[str], resolved: dict[Family, str]) -> list[subprocess.Popen[str]]:
        q: queue.Queue[tuple[Family, str] | object] = queue.Queue()
        procs = _start_mtr_processes(cmd, resolved, q)
        active_procs = len(procs)

        try:
            while active_procs > 0:
                active_procs = self.handle_mtr_item(q, active_procs)
                self.render()
        except KeyboardInterrupt:
            for proc in procs:
                proc.terminate()
        finally:
            _finish_processes(procs)
        return procs

    def drain_jobs(self) -> None:
        while self.jobs:
            self.jobs.apply_done()
            if self.jobs:
                time.sleep(0.05)


def run_live(args: argparse.Namespace, color: Color) -> int:
    cmd = _build_mtr_cmd(_mtr_command_prefix(args), args, "-l")
    resolved = _resolve(args.target)
    if not resolved:
        print(f"netcheck: Could not resolve target {args.target}", file=sys.stderr)
        return 1

    with ThreadPoolExecutor(max_workers=8) as executor:
        live = LiveRun(args=args, color=color, executor=executor)
        live.start(resolved)
        procs = live.run_mtr(cmd, resolved)
        live.drain_jobs()

    returncode, stderr = _mtr_return_status(procs)

    for hop in live.state.hops.values():
        hop.note_losses()
    live.render(done=True)
    if returncode != 0:
        if stderr:
            print(f"mtr: {stderr.strip()}", file=sys.stderr)
        return returncode
    return 0


def main() -> int:
    args = parse_args()
    try:
        return run_live(args, Color(use_color(args.color)))
    except RuntimeError as exc:
        print(f"netcheck: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
