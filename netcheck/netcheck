@dataclass
class AsyncJobs:
    executor: Executor
    callbacks: dict[Future[Any], Callable[[Any], None]] = field(default_factory=dict)
    labels: dict[Future[Any], str] = field(default_factory=dict)

    def submit(
        self,
        func: Callable[..., Any],
        *args: Any,
        apply: Callable[[Any], None],
        label: str | None = None,
    ) -> None:
        future = self.executor.submit(func, *args)
        self.callbacks[future] = apply
        self.labels[future] = label or getattr(func, "__name__", "job")

    def apply_done(self) -> None:
        for future in [f for f in self.callbacks if f.done()]:
            callback = self.callbacks.pop(future)
            self.labels.pop(future, None)
            callback(future.result())

    def pending_labels(self) -> tuple[str, ...]:
        return tuple(self.labels.values())

    def __bool__(self) -> bool:
        return bool(self.callbacks)


