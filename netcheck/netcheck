    return {Family.V4: [], Family.V6: []}


def add_ip_addr_line(out: dict[Family, list[str]], line: str) -> None:
    parts = line.split()
    if "inet" in parts:
        add_unique(out[Family.V4], token_after(parts, "inet"))
    if "inet6" not in parts:
        return

    addr = token_after(parts, "inet6")
    if not addr.lower().startswith("fe80:"):
        add_unique(out[Family.V6], addr)


def netmask_prefix(parts: list[str]) -> str:
    mask = token_after(parts, "netmask")
    if not mask:
        return ""
    try:
        return f"/{int(mask, 16).bit_count()}"
    except ValueError:
        return ""


def ifconfig_prefix(parts: list[str]) -> str:
    prefix = token_after(parts, "prefixlen")
    return f"/{prefix}" if prefix else ""


def add_ifconfig_line(out: dict[Family, list[str]], line: str) -> None:
    parts = line.strip().split()
    if len(parts) < 2:
        return
    if parts[0] == "inet":
        add_unique(out[Family.V4], f"{parts[1]}{netmask_prefix(parts)}")
        return
    if parts[0] != "inet6":
        return

    addr = parts[1].split("%", 1)[0]
    if not addr.lower().startswith("fe80:"):
        add_unique(out[Family.V6], f"{addr}{ifconfig_prefix(parts)}")


def interface_addresses(dev: str) -> dict[Family, list[str]]:
    out = empty_addr_map()
    for line in run_text(["ip", "-o", "addr", "show", "dev", dev]).splitlines():
        add_ip_addr_line(out, line)
    for line in run_text(["ifconfig", dev]).splitlines():
        add_ifconfig_line(out, line)
    return out


def parse_mtu_token(text: str) -> int | None:
    match = re.search(r"\bmtu[:\s]+(\d+)\b", text, re.IGNORECASE)
    if not match:
        return None
    try:
        return int(match.group(1))
    except ValueError:
        return None


def read_int_file(path: str) -> int | None:
    try:
        with open(path, encoding="utf-8") as fp:
            return int(fp.read().strip())
    except (OSError, ValueError):
        return None


def link_mtu(dev: str) -> int | None:
    if not dev or dev == "-":
        return None
    linux = run_text(["ip", "-o", "link", "show", "dev", dev])
    mtu = parse_mtu_token(linux)
    if mtu:
        return mtu
    return parse_mtu_token(run_text(["ifconfig", dev]))


def route_mtu(family: Family) -> int | None:
    if sys.platform == "darwin":
        cmd = ["route", "-n", "get", "default"]
        if family == Family.V6:
            cmd = ["route", "-n", "get", "-inet6", "default"]
        return parse_mtu_token(run_text(cmd))

    cmd = ["ip", "route", "get", "1.1.1.1"]
    if family == Family.V6:
        cmd = ["ip", "-6", "route", "get", "2606:4700:4700::1111"]
    return parse_mtu_token(run_text(cmd))


def interface_mtu(dev: str) -> InterfaceMtu:
    l2 = link_mtu(dev)
    v4 = route_mtu(Family.V4) or l2
    v6 = route_mtu(Family.V6) or read_int_file(f"/proc/sys/net/ipv6/conf/{dev}/mtu") or l2
    return InterfaceMtu(l2=l2, v4=v4, v6=v6)


def pick_us(addrs: list[str], source: str) -> str:
    for addr in addrs:
        if addr.split("/", 1)[0] == source:
            return addr
    return addrs[0] if addrs else source


def local_gateway_info() -> dict[Family, list[GwEntry]]:
    out = empty_gw_map()
    src = {
        Family.V4: source_address(socket.AF_INET, ("1.1.1.1", 53)),
        Family.V6: source_address(socket.AF_INET6, ("2606:4700:4700::1111", 53, 0, 0)),
    }
    routes = default_routes()
    if not routes:
        routes = [_Route(family=fam) for fam, s in src.items() if s]

    for route in routes:
        family = route.family
        addrs = interface_addresses(route.dev) if route.dev else empty_addr_map()
        out[family].append(GwEntry(
            dev=route.dev or "-",
            us=pick_us(addrs[family], src[family]) or "-",
            them=route.them or "-",
            mtu=interface_mtu(route.dev) if route.dev else InterfaceMtu(),
        ))
    return out


def is_global_ip(ip: str) -> bool:
    try:
        return ipaddress.ip_address(ip).is_global
    except ValueError:
        return False


def same_ip(left: str, right: str) -> bool:
    try:
        return ipaddress.ip_address(left) == ipaddress.ip_address(right)
    except ValueError:
        return left == right


def ip_special_purpose(ip: str) -> str:
    try:
        addr = ipaddress.ip_address(ip)
        if addr.is_global:
            return ""
        if addr.is_link_local:
            return "Link-Local"
        if addr.is_private:
            return "Unique Local (ULA)" if addr.version == 6 else "Private Use"
        if addr.is_loopback:
            return "Loopback"
        if addr.is_multicast:
            return "Multicast"
        if addr.is_reserved:
            return "Reserved"
        return "Non-Global"
    except ValueError:
        return ""


class Color:
    def __init__(self, enabled: bool) -> None:
        self.enabled = enabled

    def paint(self, text: str, code: str) -> str:
        if not self.enabled:
            return text
        return f"\033[{code}m{text}\033[0m"

    def dim(self, text: str) -> str:
        return self.paint(text, "2")

    def green(self, text: str) -> str:
        return self.paint(text, "32")

    def yellow(self, text: str) -> str:
        return self.paint(text, "33")

    def red(self, text: str) -> str:
        return self.paint(text, "31")

    def cyan(self, text: str) -> str:
        return self.paint(text, "36")

    def magenta(self, text: str) -> str:
        return self.paint(text, "35")

    def bold(self, text: str) -> str:
        return self.paint(text, "1")


def use_color(mode: str) -> bool:
    if mode == "always":
        return True
    if mode == "never" or os.environ.get("NO_COLOR"):
        return False
    return sys.stdout.isatty()


def tailscale_dns_servers() -> list[str]:
    return [server for server in system_dns_servers() if server.lower() in TAILSCALE_DNS_SERVERS]


def tailscale_dns_status(color: Color) -> str:
    servers = tailscale_dns_servers()
    if servers:
        return color.yellow(f"tailscale dns: routed via {', '.join(servers)}")
    if shutil.which("tailscale"):
        return color.dim("tailscale dns: not routed")
    return ""


def color_loss(hop: HopStats, color: Color, width: int = 0) -> str:
    value = hop.loss_pct
    lost = max(0, hop.sent - hop.recv)
    text = ("-" if value is None else f"{lost}({int(value)}%)").rjust(width)
    if value is None:
        return color.dim(text)
    if value >= 5:
        return color.red(text)
    if value > 0:
        return color.yellow(text)
    return color.green(text)


def color_latency(value: float | None, color: Color, width: int = 0) -> str:
    text = ("-" if value is None else f"{value:.1f}ms").rjust(width)
    if value is None:
        return color.dim(text)
    if value >= 150:
        return color.red(text)
    if value >= 50:
        return color.yellow(text)
    return text


def as_label(asn: str, name: str = "") -> str:
    if asn.startswith("AS"):
        asn = asn[2:]
    if asn and name:
        return f"AS{asn} - {name}"
    if asn:
        return f"AS{asn}"
    return name


def visible_hops(hops: dict[tuple[Family, int], HopStats]) -> dict[Family, list[HopStats]]:
    by_fam: dict[Family, list[HopStats]] = {}
    for fam, i in sorted(hops.keys(), key=lambda k: (k[0], k[1])):
        hop = hops[(fam, i)]
        fam_list = by_fam.setdefault(fam, [])
        if fam_list and hop.ip and hop.ip == fam_list[-1].ip:
            continue
        fam_list.append(hop)
    return by_fam


def reverse_dns(ip: str) -> str:
    try:
        hostname = socket.getnameinfo((ip, 0), 0)[0]
        return "" if hostname == ip else hostname
    except (socket.gaierror, OSError):
        return ""


DNS_SOURCES: tuple[tuple[str, str | None, float], ...] = (
    ("system", None, 1.5),
    ("1.1.1.1", "1.1.1.1", 2.5),
)
_SYSTEM_DNS_SERVERS: list[str] | None = None


def system_dns_servers() -> list[str]:
    global _SYSTEM_DNS_SERVERS
    if _SYSTEM_DNS_SERVERS is not None:
        return _SYSTEM_DNS_SERVERS

    servers: list[str] = []
    texts = [run_text(["scutil", "--dns"])] if sys.platform == "darwin" else []
    texts.append(run_text(["cat", "/etc/resolv.conf"]))
    for text in texts:
        for line in text.splitlines():
            match = re.search(r"\bnameserver(?:\[\d+\])?\s*[: ]\s*([0-9a-fA-F:.]+)", line)
            if match:
                add_unique(servers, match.group(1))
    _SYSTEM_DNS_SERVERS = servers
    return servers


def dns_source_label(source: str) -> str:
    if source != "system":
        return source
    servers = system_dns_servers()
    return f"system ({servers[0]})" if servers else source


def _system_resolve_one(host: str, family: Family) -> tuple[str | None, str]:
    sock_fam = socket.AF_INET6 if family == Family.V6 else socket.AF_INET
    try:
        infos = socket.getaddrinfo(host, None, sock_fam, socket.SOCK_STREAM)
    except (socket.gaierror, OSError) as exc:
        return None, exc.strerror or "failed"
    if not infos:
        return None, "no result"
    addr = infos[0][4][0]
    if family == Family.V6 and ipaddress.IPv6Address(addr).ipv4_mapped is not None:
        return None, "no result"
    return addr, ""


def _skip_dns_name(data: bytes, idx: int) -> int:
    while idx < len(data):
        b = data[idx]
        if b == 0:
            return idx + 1
        if b & 0xc0:
            return idx + 2
        idx += b + 1
    return idx


def _dns_query(host: str, server: str, family: Family, timeout: float) -> tuple[str | None, str]:
    qtype = 28 if family == Family.V6 else 1  # AAAA or A
    tid = os.urandom(2)
    header = tid + b"\x01\x00" + b"\x00\x01" + b"\x00\x00\x00\x00\x00\x00"
    qname = b"".join(bytes([len(p)]) + p.encode() for p in host.split(".") if p) + b"\x00"
    query = header + qname + qtype.to_bytes(2, "big") + b"\x00\x01"
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
            sock.settimeout(timeout)
            sock.sendto(query, (server, 53))
            data, _ = sock.recvfrom(4096)
    except socket.timeout:
        return None, "timeout"
    except OSError as exc:
        return None, exc.strerror or "failed"
    if len(data) < 12 or data[:2] != tid:
        return None, "bad response"
    rcode = data[3] & 0x0f
    if rcode != 0:
        return None, f"rcode {rcode}"
    ancount = int.from_bytes(data[6:8], "big")
    if ancount == 0:
        return None, "no result"
    idx = _skip_dns_name(data, 12) + 4
    for _ in range(ancount):
        if idx >= len(data):
            break
        idx = _skip_dns_name(data, idx)
        if idx + 10 > len(data):
            break
        atype = int.from_bytes(data[idx:idx+2], "big")
        rdlen = int.from_bytes(data[idx+8:idx+10], "big")
        idx += 10
        if atype == qtype:
            rdata = data[idx:idx+rdlen]
            try:
                if qtype == 1 and rdlen == 4:
                    return str(ipaddress.IPv4Address(rdata)), ""
                if qtype == 28 and rdlen == 16:
                    return str(ipaddress.IPv6Address(rdata)), ""
            except ValueError:
                pass
        idx += rdlen
    return None, "no result"


DnsResults = dict[tuple[str, Family], tuple[str | None, str]]


def _resolve(
    host: str,
    on_result: Callable[[str, Family, str | None, str], None] | None = None,
) -> tuple[dict[Family, str], DnsResults]:
    results: DnsResults = {}
    lock = threading.Lock()
    pending: list[tuple[str, Family, float]] = []
    for source, server, src_timeout in DNS_SOURCES:
        for family in FAMILIES:
            deadline = time.monotonic() + src_timeout
            def work(source=source, server=server, family=family, src_timeout=src_timeout) -> None:
                if server is None:
                    addr, err = _system_resolve_one(host, family)
                else:
                    addr, err = _dns_query(host, server, family, src_timeout)
                with lock:
                    if (source, family) in results:
                        return
                    results[(source, family)] = (addr, err)
                if on_result:
                    on_result(source, family, addr, err)
            threading.Thread(target=work, daemon=True).start()
            pending.append((source, family, deadline))
    while True:
        now = time.monotonic()
        with lock:
            newly_timed_out = [
                (s, f) for s, f, deadline in pending
                if (s, f) not in results and now >= deadline
            ]
            for key in newly_timed_out:
                results[key] = (None, "timeout")
            ready = True
            for family in FAMILIES:
                has_addr = any(
                    results.get((s, family), (None, ""))[0]
                    for s, _, _ in DNS_SOURCES
                )
                all_finished = all((s, family) in results for s, _, _ in DNS_SOURCES)
                if not (has_addr or all_finished):
                    ready = False
                    break
        if on_result:
            for s, f in newly_timed_out:
                on_result(s, f, None, "timeout")
        if ready:
            break
        time.sleep(0.05)
    resolved: dict[Family, str] = {}
    for family in FAMILIES:
        for source, _, _ in DNS_SOURCES:
            addr, _err = results.get((source, family), (None, ""))
            if addr:
                resolved[family] = addr
                break
    return resolved, results


def probe_icmp(addr: str, family: Family, timeout: float = 3.0) -> ProbeResult:
    if sys.platform == "darwin":
        # macOS: no -4/-6 flag; IPv6 needs ping6.
        # ping -W is milliseconds; ping6 has no timeout arg, rely on run_text timeout.
        if family == Family.V6:
            out = run_text(["ping6", "-c", "1", addr], timeout=timeout + 1)
        else:
            out = run_text(["ping", "-c", "1", "-W", str(int(timeout * 1000)), addr], timeout=timeout + 1)
    else:
        flag = "-6" if family == Family.V6 else "-4"
        out = run_text(["ping", flag, "-c", "1", "-W", str(int(timeout)), addr], timeout=timeout + 1)
    m = re.search(r"time[=<]([\d.]+)", out)
    if m:
        return ProbeResult(rtt_ms=float(m.group(1)), status="ok")
    return ProbeResult(rtt_ms=None)


def probe_tcp(addr: str, port: int, timeout: float = 3.0) -> ProbeResult:
    t0 = time.monotonic()
    try:
        with socket.create_connection((addr, port), timeout=timeout):
            pass
        return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
    except ConnectionRefusedError:
        return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
    except socket.timeout:
        return ProbeResult(rtt_ms=None)
    except OSError as exc:
        return ProbeResult(rtt_ms=None, status=os_error_status(exc))


def os_error_status(exc: OSError) -> str:
    return exc.strerror or str(exc) or type(exc).__name__


def probe_udp(addr: str, family: Family, port: int, timeout: float = 3.0) -> ProbeResult:
    sock_fam = socket.AF_INET6 if family == Family.V6 else socket.AF_INET
    with socket.socket(sock_fam, socket.SOCK_DGRAM) as sock:
        try:
            t0 = time.monotonic()
            sock.settimeout(timeout)
            # connect() is required for ICMP port-unreachable to surface as
            # ConnectionRefusedError on BSD/macOS; unconnected sendto() silently drops it.
            sock.connect((addr, port))
            sock.send(b"netcheck")
            sock.recv(64)
            return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
        except ConnectionRefusedError:
            return ProbeResult(rtt_ms=(time.monotonic() - t0) * 1000, status="ok")
        except socket.timeout:
            return ProbeResult(rtt_ms=None)
        except OSError as exc:
            return ProbeResult(rtt_ms=None, status=os_error_status(exc))


def parse_mtu_attempt(returncode: int, text: str) -> MtuAttempt:
    lower = text.lower()
    reached_patterns = (
        "time exceeded",
        "time to live exceeded",
        "hop limit exceeded",
    )
    if (
        returncode == 0
        and ("bytes from" in lower or re.search(r"time[=<][\d.]+", lower))
    ) or any(pattern in lower for pattern in reached_patterns):
        return MtuAttempt(ok=True, status="ok")

    too_big_patterns = (
        "message too long",
        "packet too big",
        "frag needed",
        "fragmentation needed",
        "needed and df set",
        "sendmsg: message too long",
    )
    if any(pattern in lower for pattern in too_big_patterns):
        return MtuAttempt(too_big=True, status="too-big")

    timeout_patterns = (
        "100.0% packet loss",
        "100% packet loss",
        "request timeout",
        "no answer",
    )
    if returncode == 124 or any(pattern in lower for pattern in timeout_patterns):
        return MtuAttempt(timeout=True, status="timeout")

    first_line = next((line.strip() for line in text.splitlines() if line.strip()), "")
    return MtuAttempt(status=first_line or "failed")


def parse_mtr_reached_hops(text: str) -> frozenset[int]:
    reached: set[int] = set()
    for raw_line in text.splitlines():
        parts = raw_line.strip().split()
        if len(parts) < 2 or parts[0] not in {"h", "p"}:
            continue
        try:
            reached.add(int(parts[1]))
        except ValueError:
            pass
    return frozenset(reached)


@dataclass(frozen=True)
class MtrMtuDiscoverer:
    """Find the largest mtr packet size that still reaches each responsive hop.

    Hop numbers are zero-based internally, so hop index 0 is probed with TTL 1.
    A successful probe means that hop produced an mtr h/p line for that packet
    size; silent hops are not distinguished from drops here because the main
    trace decides which hops are responsive enough to probe.
    """

    prefix: list[str]
    family: Family
    addr: str
    max_packet: int
    timeout: float
    deadline: float | None = None
    progress: Callable[[int, MtuResult], None] | None = None

    def timed_out(self) -> bool:
        return self.deadline is not None and time.monotonic() >= self.deadline

    def remaining_timeout(self) -> float:
        # -G is the per-probe wait. The process wrapper needs extra room for
        # mtr startup, sudo -n, and stdout flushes; otherwise every 250 ms probe
        # can look like a script-level timeout.
        timeout = max(1.0, self.timeout + 0.75)
        if self.deadline is None:
            return timeout
        return max(0.1, min(timeout, self.deadline - time.monotonic()))

    def cmd(self, packet_size: int, ttl: int) -> list[str]:
        family_flag = "-6" if self.family == Family.V6 else "-4"
        return [
            *self.prefix,
            family_flag,
            "-u",
            "-l",
            "-n",
            "-c",
            "1",
            "-i",
            "0.05",
            "-G",
            str(self.timeout),
            "-m",
            str(ttl),
            "-s",
            str(packet_size),
            self.addr,
        ]

    def run_once(self, packet_size: int, ttl: int) -> tuple[int, MtuAttempt, frozenset[int]]:
        if self.timed_out():
            return 124, MtuAttempt(timeout=True, status="timeout"), frozenset()
        returncode, text = run_output(self.cmd(packet_size, ttl), timeout=self.remaining_timeout())
        attempt = parse_mtu_attempt(returncode, text)
        return returncode, attempt, parse_mtr_reached_hops(text)

    def probe_hop(self, packet_size: int, hop_index: int, attempts: int = MTU_MAX_RETRIES) -> MtrMtuProbe:
        reached: set[int] = set()
        too_big = False
        timed_out = False
        status = "timeout"
        ttl = hop_index + 1

        for _ in range(attempts):
            if _STOP_EVENT.is_set() or self.timed_out():
                break
            returncode, attempt, attempt_reached = self.run_once(packet_size, ttl)
            reached.update(attempt_reached)
            too_big = too_big or attempt.too_big
            timed_out = timed_out or returncode == 124
            status = attempt.status
            if hop_index in reached or attempt.too_big:
                break

        return MtrMtuProbe(
            reached=frozenset(reached),
            too_big=too_big,
            timeout=timed_out,
            status=status,
        )

    def hop_allows(self, hop_index: int, packet_size: int) -> bool:
        return hop_index in self.probe_hop(packet_size, hop_index).reached

    def publish_result(self, hop_index: int, mtu: int | None, status: str = "ok") -> MtuResult:
        result = MtuResult(mtu=mtu, status=status)
        self.note_progress(hop_index, result)
        return result

    def find_hop_mtu(self, hop_index: int, max_packet_known_blocked: bool = False) -> MtuResult:
        if _STOP_EVENT.is_set() or self.timed_out():
            return MtuResult(mtu=None, status="timeout")
        small_packet = min(MTU_MIN_PACKET, self.max_packet)
        if not self.hop_allows(hop_index, small_packet):
            return self.publish_result(hop_index, None, f"<{small_packet}")
        self.publish_result(hop_index, small_packet, "probing")
        if not max_packet_known_blocked and self.hop_allows(hop_index, self.max_packet):
            return self.publish_result(hop_index, self.max_packet)

        low = small_packet
        high = self.max_packet - 1
        while low < high:
            if _STOP_EVENT.is_set() or self.timed_out():
                return self.publish_result(hop_index, None, "timeout")
            mid = (low + high + 1) // 2
            if self.hop_allows(hop_index, mid):
                low = mid
                # Publish the current lower bound during the binary search so
                # the live table shows progress before the hop is finalized.
                self.publish_result(hop_index, low, "probing")
            else:
                high = mid - 1
        return self.publish_result(hop_index, low)

    def note_progress(self, hop_index: int, result: MtuResult) -> None:
        if self.progress:
            self.progress(hop_index, result)

    def publish_max_packet_prefix(self, hop_indices: tuple[int, ...], through: int) -> dict[int, MtuResult]:
        results: dict[int, MtuResult] = {}
        for hop_index in hop_indices:
            if hop_index > through:
                break
            results[hop_index] = self.publish_result(hop_index, self.max_packet)
        return results

    def split_at_farthest_max_packet_hop(self, hop_indices: tuple[int, ...]) -> int | None:
        for hop_index in reversed(hop_indices):
            if _STOP_EVENT.is_set() or self.timed_out():
                return None
            if self.hop_allows(hop_index, self.max_packet):
                return hop_index
        return None

    def full_map(self, hop_indices: tuple[int, ...]) -> dict[int, MtuResult]:
        hop_indices = tuple(sorted(hop_indices))
        results: dict[int, MtuResult] = {}
        farthest_max_hop = self.split_at_farthest_max_packet_hop(hop_indices)
        if farthest_max_hop is not None:
            results.update(self.publish_max_packet_prefix(hop_indices, farthest_max_hop))

        remaining = tuple(hop for hop in hop_indices if hop not in results)
        for i, hop_index in enumerate(remaining):
            if _STOP_EVENT.is_set():
                return self.with_inferred_forwarding_mtu(results)
            if self.timed_out():
                for rest in remaining[i:]:
                    results[rest] = MtuResult(mtu=None, status="timeout")
                return self.with_inferred_forwarding_mtu(results)
            results[hop_index] = self.find_hop_mtu(hop_index, max_packet_known_blocked=True)
        return self.with_inferred_forwarding_mtu(results)

    def with_inferred_forwarding_mtu(self, results: dict[int, MtuResult]) -> dict[int, MtuResult]:
        # If a later hop answered with size N, every earlier hop forwarded N
        # even if its own ICMP TTL-exceeded response was rate-limited or absent.
        best_later: int | None = None
        inferred = dict(results)
        for hop_index in sorted(inferred, reverse=True):
            result = inferred[hop_index]
            if result.mtu is None and best_later is not None:
                inferred[hop_index] = MtuResult(mtu=best_later, status="inferred")
                continue
            if result.mtu is not None:
                best_later = result.mtu if best_later is None else max(best_later, result.mtu)
        return inferred


def _run_probe(key: ProbeKey, addr: str) -> ProbeResult:
    match key.proto:
        case Proto.ICMP:
            return probe_icmp(addr, key.family)
        case Proto.TCP:
            assert key.port is not None
            return probe_tcp(addr, key.port)
        case Proto.UDP:
            assert key.port is not None
            return probe_udp(addr, key.family, key.port)
        case _:
            raise ValueError(f"unknown proto: {key.proto}")


def _fmt_probe(result: ProbeResult | None, color: Color) -> str:
    if result is None:
        return color.dim("…")
    if result.rtt_ms is not None:
        return color.green(f"{result.rtt_ms:.1f}ms")
    return color.red(result.status)


def _format_as_alloc(hop: HopStats, color: Color, width: int = 0) -> str:
    text = get_as_alloc_str(hop)
    if not text and hop.alloc_status == LookupStatus.PENDING:
        text = "…"
    if not text:
        text = "-"
    return text.ljust(width)


def _rdns_display(hop: HopStats) -> str:
    if not hop.ip:
        return ""
    if hop.rdns is None:
        return "…"
    return hop.rdns or "-"


def get_as_alloc_str(hop: HopStats) -> str:
    if hop.asn or hop.as_name:
        return as_label(hop.asn, hop.as_name)
    if hop.ip:
        return ip_special_purpose(hop.ip)
    return ""


def pub_ip_text(info: PubIpInfo) -> str:
    return "…" if info.ip is None else (info.ip or "-")


def pub_rdns_text(info: PubIpInfo) -> str:
    if not info.ip:
        return ""
    rdns = "…" if info.rdns is None else (info.rdns or "-")
    return f" ({rdns})"


def nat_label(family: Family, entry: GwEntry, pub_ip: str, color: Color) -> str:
    us_ip = entry.us.split("/")[0] if entry.us != "-" else ""
    if not us_ip or us_ip == pub_ip:
        return ""
    if family == Family.V4:
        return color.yellow(" (NAT)")
    return color.yellow(f" ({v6_nat_kind(us_ip, pub_ip)})")


def v6_nat_kind(us_ip: str, pub_ip: str) -> str:
    try:
        us_v6 = ipaddress.IPv6Address(us_ip)
        pub_v6 = ipaddress.IPv6Address(pub_ip)
    except ValueError:
        return "NAT66"
    return "NPTv6" if us_v6.packed[8:] == pub_v6.packed[8:] else "NAT66"


def pub_line(family: Family, entries: list[GwEntry], info: PubIpInfo, color: Color) -> str:
    nat = nat_label(family, entries[0], info.ip, color) if info.ip and entries else ""
    return f"pub: {color.cyan(pub_ip_text(info))}{pub_rdns_text(info)}{nat}"


def color_mtu_value(value: int | None, color: Color) -> str:
    if value is None:
        return color.dim("-")
    text = str(value)
    return color.cyan(text) if value == 1500 else color.yellow(text)


def mtu_summary(mtu: InterfaceMtu, color: Color) -> str:
    return (
        f"l2={color_mtu_value(mtu.l2, color)} "
        f"ipv4={color_mtu_value(mtu.v4, color)} "
        f"ipv6={color_mtu_value(mtu.v6, color)}"
    )


def print_interface_mtu_block(gw: dict[Family, list[GwEntry]], color: Color) -> None:
    seen: set[str] = set()
    for family in FAMILIES:
        for entry in gw.get(family) or []:
            if entry.dev == "-" or entry.dev in seen:
                continue
            seen.add(entry.dev)
            print(f"  if: {color.cyan(entry.dev)}, mtu: {mtu_summary(entry.mtu, color)}")


def color_gateway_them(family: Family, them: str, color: Color) -> str:
    if family == Family.V6 and "%" in them:
        addr, iface = them.rsplit("%", 1)
        if ip_special_purpose(addr) == "Link-Local":
            return f"{color.cyan(addr)}%{color.magenta(iface)}"
    return color.cyan(them)


def print_dns_block(target: str, dns_results: DnsResults, color: Color) -> None:
    if not dns_results:
        return
    print(f"{color.bold('dns')}: {target}")
    for source, _, _ in DNS_SOURCES:
        label = dns_source_label(source)
        parts: list[str] = []
        for family in FAMILIES:
            entry = dns_results.get((source, family))
            if entry is None:
                continue
            addr, err = entry
            if addr:
                parts.append(f"{family}={color.cyan(addr)}")
            else:
                parts.append(f"{family}={color.red(err or 'failed')}")
        if parts:
            print(f"  {label}: {'  '.join(parts)}")


def print_gateway_block(gw: dict[Family, list[GwEntry]], pub_info: dict[Family, PubIpInfo], color: Color) -> None:
    print(f"{color.bold('gw')}:")
    print_interface_mtu_block(gw, color)
    for family in FAMILIES:
        entries = gw.get(family) or []
        pub_str = pub_line(family, entries, pub_info.get(family, PubIpInfo()), color)
        if not entries:
            print(f"  {family}: -")
            print(f"      {pub_str}")
            continue
        for i, entry in enumerate(entries):
            print(
                f"  {family}: "
                f"dev: {color.cyan(entry.dev)}, "
                f"us: {color.cyan(entry.us)}, "
                f"them: {color_gateway_them(family, entry.them, color)}"
            )
            if i == 0:
                print(f"      {pub_str}")


@dataclass(frozen=True)
class RenderWidths:
    loss: int
    ip: int
    mtu: int
    as_alloc: int
    rdns: int


def _mtu_plain(hop: HopStats, previous_mtu: int | None) -> str:
    if not hop.ip:
        return "-"
    if hop.mtu is None:
        return "..."
    if hop.mtu.mtu is None:
        return hop.mtu.status or "?"

    text = f">={hop.mtu.mtu}" if hop.mtu.status in {"inferred", "probing"} else str(hop.mtu.mtu)
    is_lower_bound = hop.mtu.status in {"inferred", "probing"}
    if previous_mtu is not None and hop.mtu.mtu < previous_mtu and not is_lower_bound:
        text += "!"
    if hop.mtu.blackhole:
        text += " bh?"
    return text


def _format_mtu(hop: HopStats, previous_mtu: int | None, color: Color, width: int = 0) -> str:
    text = _mtu_plain(hop, previous_mtu).rjust(width)
    if hop.mtu is None:
        return color.dim(text)
    if hop.mtu.mtu is None:
        return color.red(text)
    if hop.mtu.status in {"inferred", "probing"}:
        return color.yellow(text)
    if hop.mtu.blackhole:
        return color.red(text)
    if previous_mtu is not None and hop.mtu.mtu < previous_mtu:
        return color.yellow(text)
    return text


def render_widths(hops: list[HopStats], mtu_enabled: bool) -> RenderWidths:
    rdns = max((len(_rdns_display(hop)) for hop in hops if hop.ip), default=0)
    return RenderWidths(
        loss=max(max((len(f"{max(0, hop.sent - hop.recv)}({int(hop.loss_pct)}%)") for hop in hops if hop.loss_pct is not None), default=7), 7),
        ip=max((len(hop.ip or "-") for hop in hops), default=15),
        mtu=9 if mtu_enabled else 0,
        as_alloc=max(max((len(get_as_alloc_str(hop)) for hop in hops if hop.ip), default=13), 13),
        rdns=max(rdns, 4) if rdns > 0 else 0,
    )


def group_probe_keys(probes: dict[ProbeKey, ProbeResult | None]) -> tuple[dict[str, list[ProbeKey]], list[Family]]:
    labels: dict[str, list[ProbeKey]] = {}
    fams: list[Family] = []
    for key in probes:
        labels.setdefault(key.label(), []).append(key)
        if key.family not in fams:
            fams.append(key.family)
    return labels, fams


def print_probe_block(probes: dict[ProbeKey, ProbeResult | None], color: Color) -> None:
    label_keys, fams = group_probe_keys(probes)
    label_w = max(len(label) for label in label_keys)
    print(f"{color.bold('probe')}:")
    for label, keys in label_keys.items():
        key_map = {key.family: key for key in keys}
        cols = "  ".join(
            f"{fam}: {_fmt_probe(probes.get(key_map[fam]), color)}"
            for fam in fams
            if fam in key_map
        )
        print(f"  {label.ljust(label_w)}  {cols}")


def print_task_block(tasks: tuple[str, ...], color: Color) -> None:
    # These are background annotations still running after or alongside the
    # main trace. Keeping them below the trace makes it clear that the table is
    # still valid while enrichment work continues.
    if not tasks:
        return
    print(f"{color.bold('tasks')}:")
    for task in tasks[:8]:
        print(f"  {color.yellow('processing')} {task}")
    if len(tasks) > 8:
        print(f"  {color.yellow('processing')} ... {len(tasks) - 8} more")


def trace_header(widths: RenderWidths) -> str:
    mtu = f" {'mtu':>{widths.mtu}}" if widths.mtu > 0 else ""
    rdns = f" {'rdns'.ljust(widths.rdns)}" if widths.rdns > 0 else ""
    return f"{'hop':>3} {'loss':>{widths.loss}} {'snt':>4} {'best':>8}{mtu} {'ip':<{widths.ip}} {'as/allocation':<{widths.as_alloc}}{rdns}"


def print_trace_row(hop: HopStats, widths: RenderWidths, color: Color, previous_mtu: int | None = None) -> None:
    mtu_col = f" {_format_mtu(hop, previous_mtu, color, widths.mtu)}" if widths.mtu > 0 else ""
    rdns_col = f" {_rdns_display(hop)}" if widths.rdns > 0 else ""
    print(
        f"{hop.index + 1:>3} "
        f"{color_loss(hop, color, widths.loss)} "
        f"{hop.sent:>4} "
        f"{color_latency(hop.best_ms, color, 8)}"
        f"{mtu_col} "
        f"{color.cyan((hop.ip or '-').ljust(widths.ip))} "
        f"{_format_as_alloc(hop, color, widths.as_alloc)}"
        f"{rdns_col}"
    )


def print_trace_blocks(visible_by_fam: dict[Family, list[HopStats]], widths: RenderWidths, color: Color) -> None:
    header = trace_header(widths)
    for fam in FAMILIES:
        if fam not in visible_by_fam:
            continue
        print(color.bold(f"trace {fam}:"))
        print(header)
        previous_mtu: int | None = None
        for hop in visible_by_fam[fam]:
            print_trace_row(hop, widths, color, previous_mtu)
            if hop.mtu and hop.mtu.mtu is not None:
                previous_mtu = hop.mtu.mtu


def render_live(
    target: str,
    gw: dict[Family, list[GwEntry]],
    hops: dict[tuple[Family, int], HopStats],
    color: Color,
    *,
    clear: bool,
    done: bool = False,
    probes: dict[ProbeKey, ProbeResult | None] | None = None,
    pub_info: dict[Family, PubIpInfo] | None = None,
    dns_results: DnsResults | None = None,
    mtu_enabled: bool = False,
    phase: str = "running",
    tasks: tuple[str, ...] = (),
) -> None:
    visible_by_fam = visible_hops(hops)
    widths = render_widths([hop for fam_hops in visible_by_fam.values() for hop in fam_hops], mtu_enabled)
    if clear:
        print("\033[H\033[2J", end="")

    tailscale_status = tailscale_dns_status(color)
    if tailscale_status:
        print(tailscale_status)

    if done:
        status = color.green("done")
    elif phase == "interrupted":
        status = color.red("interrupted")
    elif phase == "processing":
        status = color.yellow("processing")
    else:
        status = color.yellow("running")
    print(f"{color.bold('target')}: {target}  {color.bold('status')}: {status}")
    if dns_results:
        print_dns_block(target, dns_results, color)
    print_gateway_block(gw, pub_info or {fam: PubIpInfo() for fam in FAMILIES}, color)
    if probes:
        print_probe_block(probes, color)
    print()
    print_trace_blocks(visible_by_fam, widths, color)
    if tasks:
        print()
        print_task_block(tasks, color)
    sys.stdout.flush()


@dataclass
class AllocationState:
    by_ip: dict[str, tuple[str, str]] = field(default_factory=dict)
    prefixes: list[PrefixAllocation] = field(default_factory=list)

    def cached(self, ip: str) -> tuple[str, str]:
        if ip in self.by_ip:
            return self.by_ip[ip]
        route = best_prefix_match(self.prefixes, ip)
        if not route:
            return "", ""
        self.by_ip[ip] = (route.asn, route.name)
        return route.asn, route.name

    def remember_prefix(self, route: PrefixAllocation) -> None:
        if route not in self.prefixes:
            self.prefixes.append(route)


@dataclass
class RdnsState:
    cache: dict[str, str] = field(default_factory=dict)
    submitted: set[str] = field(default_factory=set)


@dataclass
class MtuState:
    cache: dict[HopKey, MtuResult] = field(default_factory=dict)


@dataclass
class PublicIpState:
    info: dict[Family, PubIpInfo] = field(default_factory=lambda: {fam: PubIpInfo() for fam in FAMILIES})


@dataclass
class LookupState:
    pending: set[str] = field(default_factory=set)
    retry_at: dict[str, float] = field(default_factory=dict)
    attempts: dict[str, int] = field(default_factory=dict)
    status: dict[str, LookupStatus] = field(default_factory=dict)

    def should_start(self, ip: str) -> bool:
        if self.status.get(ip) == LookupStatus.MISSING:
            return False
        if ip in self.pending:
            return False
        retry_at = self.retry_at.get(ip)
        return retry_at is None or time.monotonic() >= retry_at

    def started(self, ip: str) -> LookupStatus:
        self.pending.add(ip)
        self.attempts[ip] = self.attempts.get(ip, 0) + 1
        return LookupStatus.PENDING

    def done(self, ip: str, *, retry: bool) -> LookupStatus:
        self.pending.discard(ip)
        if retry:
            self.retry_at[ip] = time.monotonic() + 1.0
            return LookupStatus.PENDING
        self.retry_at.pop(ip, None)
        self.attempts.pop(ip, None)
        return LookupStatus.UNKNOWN

    def missing(self, ip: str) -> LookupStatus:
        self.done(ip, retry=False)
        return LookupStatus.MISSING

    def set_status(self, ip: str, status: LookupStatus) -> None:
        if status != LookupStatus.UNKNOWN:
            self.status[ip] = status
        else:
            self.status.pop(ip, None)


@dataclass
class TraceState:
    hops: dict[HopKey, HopStats] = field(default_factory=dict)
    probes: dict[ProbeKey, ProbeResult | None] = field(default_factory=dict)
    public: PublicIpState = field(default_factory=PublicIpState)
    allocation: AllocationState = field(default_factory=AllocationState)
    lookup: LookupState = field(default_factory=LookupState)
    rdns: RdnsState = field(default_factory=RdnsState)
    mtu: MtuState = field(default_factory=MtuState)

    def apply_asn(self, ip: str, asn: str, as_name: str) -> None:
        self.allocation.by_ip[ip] = (asn, as_name)
        self.set_lookup_status(ip, LookupStatus.UNKNOWN)
        for hop in self.hops.values():
            if hop.ip == ip:
                hop.asn = asn
                hop.as_name = as_name

    def apply_prefix(self, prefix: str, asn: str, as_name: str) -> None:
        try:
            network = ipaddress.ip_network(prefix, strict=False)
        except ValueError:
            return
        route = PrefixAllocation(network=network, asn=asn, name=as_name)
        self.allocation.remember_prefix(route)
        for hop in self.hops.values():
            if hop.ip and route.contains(hop.ip):
                self.apply_asn(hop.ip, route.asn, route.name)

    def cached_allocation(self, ip: str) -> tuple[str, str]:
        asn, name = self.allocation.cached(ip)
        if asn or name:
            self.set_lookup_status(ip, LookupStatus.UNKNOWN)
            for hop in self.hops.values():
                if hop.ip == ip:
                    hop.asn = asn
                    hop.as_name = name
        return asn, name

    def apply_rdns(self, ip: str, hostname: str) -> None:
        self.rdns.cache[ip] = hostname
        for hop in self.hops.values():
            if hop.ip == ip:
                hop.rdns = hostname

    def apply_mtu(self, key: HopKey, result: MtuResult) -> None:
        self.mtu.cache[key] = result
        hop = self.hops.get(key)
        if hop:
            hop.mtu = result

    def apply_mtu_map(self, family: Family, results: dict[int, MtuResult]) -> None:
        for index, result in results.items():
            self.apply_mtu((family, index), result)

    def note_hop_ip(self, hop: HopStats, ip: str, jobs: AsyncJobs) -> None:
        hop.ip = ip
        hop.asn, hop.as_name = self.cached_allocation(ip)
        hop.alloc_status = self.lookup.status.get(ip, LookupStatus.UNKNOWN)

        if ip in self.rdns.cache:
            hop.rdns = self.rdns.cache[ip]
        elif is_global_ip(ip):
            hop.rdns = None
            if ip not in self.rdns.submitted:
                self.rdns.submitted.add(ip)
                jobs.submit(
                    reverse_dns,
                    ip,
                    apply=lambda hostname, ip=ip: self.apply_rdns(ip, hostname),
                    label=f"reverse dns {ip}",
                )
        else:
            hop.rdns = ""

        mtu = self.mtu.cache.get((hop.family, hop.index))
        if mtu:
            hop.mtu = mtu

    def start_public_ip_checks(self, jobs: AsyncJobs) -> None:
        if _STOP_EVENT.is_set():
            return
        for fam in FAMILIES:
            jobs.submit(
                fetch_pub_ip,
                fam,
                apply=lambda result, fam=fam: self.apply_public_ip(jobs, fam, result[1]),
                label=f"public ip {fam}",
            )

    def apply_public_ip(self, jobs: AsyncJobs, fam: Family, ip: str) -> None:
        self.public.info[fam].ip = ip
        if not ip:
            self.public.info[fam].rdns = ""
            return
        jobs.submit(
            reverse_dns,
            ip,
            apply=lambda hostname, fam=fam, ip=ip: self.apply_public_rdns(fam, ip, hostname),
            label=f"public reverse dns {fam} {ip}",
        )

    def apply_public_rdns(self, fam: Family, ip: str, hostname: str) -> None:
        if self.public.info[fam].ip == ip:
            self.public.info[fam].rdns = hostname

    def should_lookup(self, ip: str) -> bool:
        return self.lookup.should_start(ip)

    def note_lookup_started(self, ip: str) -> None:
        self.set_lookup_status(ip, self.lookup.started(ip))

    def note_lookup_done(self, ip: str, *, retry: bool) -> None:
        self.set_lookup_status(ip, self.lookup.done(ip, retry=retry))

    def note_lookup_missing(self, ip: str) -> None:
        self.set_lookup_status(ip, self.lookup.missing(ip))

    def set_lookup_status(self, ip: str, status: LookupStatus) -> None:
        self.lookup.set_status(ip, status)
        for hop in self.hops.values():
            if hop.ip == ip:
                hop.alloc_status = status


def probe_keys(args: argparse.Namespace, fam: Family) -> list[ProbeKey]:
    keys = [ProbeKey(Proto.ICMP, fam)]
    if args.tcp_port:
        keys.append(ProbeKey(Proto.TCP, fam, args.tcp_port))
    if args.udp_port:
        keys.append(ProbeKey(Proto.UDP, fam, args.udp_port))
    return keys


def process_mtr_line(
    state: TraceState,
    jobs: AsyncJobs,
    fam: Family,
    raw_line: str,
) -> None:
    parts = raw_line.strip().split()
    if len(parts) < 3:
        return

    try:
        index = int(parts[1])
    except ValueError:
        return

    key = (fam, index)
    hop = state.hops.setdefault(key, HopStats(index=index, family=fam))

    match parts[0]:
        case "x":
            hop.note_probe(parts[2])
        case "h":
            state.note_hop_ip(hop, parts[2], jobs)
        case "p":
            note_probe_reply(hop, parts)


def apply_allocation(state: TraceState, ip: str, result: AllocationResult) -> None:
    for route in result.routes:
        if route in state.allocation.prefixes:
            continue
        state.allocation.remember_prefix(route)
        for hop in state.hops.values():
            if hop.ip and route.contains(hop.ip) and not state.allocation.by_ip.get(hop.ip):
                state.apply_asn(hop.ip, route.asn, route.name)

    if result.temporary_failure:
        if state.lookup.attempts.get(ip, 0) >= WHOIS_LOOKUP_MAX_ATTEMPTS:
            state.note_lookup_missing(ip)
        else:
            state.note_lookup_done(ip, retry=True)
        return
    if result.no_entry:
        if result.name:
            state.apply_asn(ip, result.asn, result.name)
        else:
            state.note_lookup_missing(ip)
        return
    if result.prefix and (result.asn or result.name):
        state.apply_prefix(result.prefix, result.asn, result.name)
        state.note_lookup_done(ip, retry=False)
        return
    if result.asn or result.name:
        state.apply_asn(ip, result.asn, result.name)
        state.note_lookup_done(ip, retry=False)
        return
    state.note_lookup_done(ip, retry=True)


def note_probe_reply(hop: HopStats, parts: list[str]) -> None:
    try:
        hop.note_reply(int(parts[2]), parts[3] if len(parts) >= 4 else "")
    except ValueError:
        pass


def _read_mtr_stdout(proc: subprocess.Popen[str], fam: Family, out: queue.Queue[tuple[Family, str] | object]) -> None:
    assert proc.stdout is not None
    for raw_line in proc.stdout:
        out.put((fam, raw_line))
    out.put(MTR_DONE)


def _start_mtr_processes(cmd: list[str], resolved: dict[Family, str], out: queue.Queue[tuple[Family, str] | object]) -> list[subprocess.Popen[str]]:
    procs: list[subprocess.Popen[str]] = []
    for fam, addr in resolved.items():
        fam_cmd = cmd.copy()
        fam_cmd[-1] = addr
        proc = subprocess.Popen(
            fam_cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        procs.append(proc)
        threading.Thread(target=_read_mtr_stdout, args=(proc, fam, out), daemon=True).start()
    return procs


def _finish_processes(procs: list[subprocess.Popen[str]]) -> None:
    for proc in procs:
        try:
            proc.wait(timeout=1)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=1)


def _mtr_return_status(procs: list[subprocess.Popen[str]]) -> tuple[int, str]:
    stderr = ""
    returncode = 0
    for proc in procs:
        if proc.stderr is not None:
            err = proc.stderr.read().strip()
            if err:
                stderr += f"{err}\n"
        if proc.returncode not in (0, -15):
            returncode = proc.returncode or 1
    return returncode, stderr


@dataclass(frozen=True)
class MtuProbePlan:
    family: Family
    addr: str
    hop_indices: tuple[int, ...]
    max_packet: int


@dataclass
class MtuDiscoveryRuntime:
    progress: queue.Queue[tuple[Family, int, MtuResult]] = field(default_factory=queue.Queue)
    started: set[Family] = field(default_factory=set)

    def has_started(self, family: Family) -> bool:
        return family in self.started

    def mark_started(self, family: Family) -> None:
        self.started.add(family)

    def publish(self, family: Family, hop: int, result: MtuResult) -> None:
        self.progress.put((family, hop, result))

    def drain_into(self, state: TraceState) -> None:
        while True:
            try:
                fam, hop, result = self.progress.get_nowait()
            except queue.Empty:
                return
            state.apply_mtu((fam, hop), result)


@dataclass
class LiveRun:
    args: argparse.Namespace
    color: Color
    executor: Executor
    mtr_prefix: list[str]
    state: TraceState = field(default_factory=TraceState)
    gw: dict[Family, list[GwEntry]] = field(default_factory=local_gateway_info)
    dns_results: DnsResults = field(default_factory=dict)
    jobs: AsyncJobs = field(init=False)
    mtu_runtime: MtuDiscoveryRuntime = field(default_factory=MtuDiscoveryRuntime)
    clear: bool = field(init=False)

    def __post_init__(self) -> None:
        self.jobs = AsyncJobs(self.executor)
        self.clear = self.color.enabled and sys.stdout.isatty()

    def start(self, resolved: dict[Family, str]) -> None:
        self.state.start_public_ip_checks(self.jobs)
        self.start_endpoint_probes(resolved)

    def start_endpoint_probes(self, resolved: dict[Family, str]) -> None:
        if _STOP_EVENT.is_set():
            return
        for fam, addr in resolved.items():
            for key in probe_keys(self.args, fam):
                self.state.probes[key] = None
                self.jobs.submit(
                    _run_probe,
                    key,
                    addr,
                    apply=lambda result, key=key: self.state.probes.__setitem__(key, result),
                    label=f"endpoint probe {key.label()} {fam}",
                )

    def start_mtu_checks(self, resolved: dict[Family, str]) -> None:
        if self.args.no_mtu:
            return
        for plan in self.mtu_probe_plans(resolved):
            self.submit_mtu_probe_plan(plan)

    def mtu_probe_plans(self, resolved: dict[Family, str]) -> Iterator[MtuProbePlan]:
        for fam, addr in resolved.items():
            plan = self.mtu_probe_plan(fam, addr)
            if plan:
                yield plan

    def mtu_probe_plan(self, family: Family, addr: str) -> MtuProbePlan | None:
        if self.mtu_runtime.has_started(family):
            return None
        target_hop = self.target_hop_index(family, addr)
        if target_hop is None:
            return None
        target = self.state.hops.get((family, target_hop))
        # Start before the main trace finishes, but only after the target hop
        # has five main probes. That gives loss/route discovery enough signal
        # and avoids MTU work for unreachable targets.
        if target is None or target.sent < MTU_START_AFTER_PROBES:
            return None
        hop_indices = self.mtu_probe_hop_indices(family, target_hop)
        if not hop_indices:
            return None
        limit = self.mtu_limit(family)
        if limit is None or limit < MTU_MIN_PACKET:
            return None
        return MtuProbePlan(
            family=family,
            addr=addr,
            hop_indices=hop_indices,
            max_packet=limit,
        )

    def submit_mtu_probe_plan(self, plan: MtuProbePlan) -> None:
        hop_budget = max(1.0, self.args.mtu_timeout * MTU_MAX_RETRIES * 2.0)
        mtu_deadline = time.monotonic() + max(self.args.mtu_total_timeout, hop_budget * len(plan.hop_indices))
        discoverer = MtrMtuDiscoverer(
            self.mtr_prefix,
            plan.family,
            plan.addr,
            plan.max_packet,
            self.args.mtu_timeout,
            mtu_deadline,
            progress=lambda hop, result, fam=plan.family: self.mtu_runtime.publish(fam, hop, result),
        )
        self.jobs.submit(
            discoverer.full_map,
            plan.hop_indices,
            apply=lambda result, fam=plan.family: self.state.apply_mtu_map(fam, result),
            label=f"mtu discovery {plan.family} {len(plan.hop_indices)} responsive hops",
        )
        self.mtu_runtime.mark_started(plan.family)

    def target_hop_index(self, family: Family, addr: str) -> int | None:
        matches = [
            hop.index
            for (fam, _), hop in self.state.hops.items()
            if fam == family and same_ip(hop.ip, addr)
        ]
        return min(matches) if matches else None

    def mtu_probe_hop_indices(self, family: Family, target_hop: int) -> tuple[int, ...]:
        # Hops that never answered the main mtr are skipped. Probing them again
        # mostly measures ICMP rate limiting, not forwarding MTU.
        return tuple(
            hop.index
            for (fam, _), hop in sorted(self.state.hops.items(), key=lambda item: item[0][1])
            if fam == family and hop.index <= target_hop and hop.recv > 0
        )

    def apply_pending_mtu_progress(self) -> None:
        self.mtu_runtime.drain_into(self.state)

    def service_background_jobs(self, resolved: dict[Family, str]) -> None:
        self.apply_pending_mtu_progress()
        self.jobs.apply_done()
        self.apply_pending_mtu_progress()
        self.start_mtu_checks(resolved)
        self.schedule_due_lookups()

    def mtu_enabled(self) -> bool:
        return not self.args.no_mtu and any(self.mtu_limit(fam) is not None for fam in FAMILIES)

    def mtu_limit(self, family: Family) -> int | None:
        entries = self.gw.get(family) or []
        if not entries:
            return None
        mtu = entries[0].mtu
        return mtu.v6 if family == Family.V6 else mtu.v4

    def render(self, *, done: bool = False, phase: str = "running") -> None:
        render_live(
            self.args.target,
            self.gw,
            self.state.hops,
            self.color,
            clear=self.clear,
            done=done,
            probes=self.state.probes,
            pub_info=self.state.public.info,
            dns_results=self.dns_results,
            mtu_enabled=self.mtu_enabled(),
            phase=phase,
            tasks=self.jobs.pending_labels(),
        )

    def handle_mtr_item(
        self,
        q: queue.Queue[tuple[Family, str] | object],
        active_procs: int,
        resolved: dict[Family, str],
    ) -> int:
        try:
            item = q.get(timeout=0.1)
        except queue.Empty:
            self.service_background_jobs(resolved)
            return active_procs

        if item is MTR_DONE:
            self.service_background_jobs(resolved)
            return active_procs - 1

        fam, raw_line = item
        process_mtr_line(self.state, self.jobs, fam, raw_line)
        self.service_background_jobs(resolved)
        return active_procs

    def schedule_due_lookups(self) -> None:
        if _STOP_EVENT.is_set():
            return
        if self.state.lookup.pending:
            return
        for ip in dict.fromkeys(hop.ip for hop in self.state.hops.values() if hop.ip):
            if not is_global_ip(ip) or self.state.cached_allocation(ip) != ("", ""):
                continue
            if not self.state.should_lookup(ip):
                continue
            self.state.note_lookup_started(ip)
            self.jobs.submit(
                allocation_lookup,
                ip,
                self.args.no_whois,
                apply=lambda result, ip=ip: apply_allocation(self.state, ip, result),
                label=f"whois allocation {ip}",
            )
            return

    def run_mtr(self, cmd: list[str], resolved: dict[Family, str]) -> list[subprocess.Popen[str]]:
        q: queue.Queue[tuple[Family, str] | object] = queue.Queue()
        procs = _start_mtr_processes(cmd, resolved, q)
        active_procs = len(procs)

        try:
            while active_procs > 0:
                active_procs = self.handle_mtr_item(q, active_procs, resolved)
                self.render()
        except KeyboardInterrupt:
            _STOP_EVENT.set()
            for proc in procs:
                proc.terminate()
            raise
        finally:
            _finish_processes(procs)
        return procs

    def drain_jobs(self, resolved: dict[Family, str]) -> None:
        while True:
            if _STOP_EVENT.is_set():
                return
            self.service_background_jobs(resolved)
            if not self.jobs:
                return
            self.render(phase="processing")
            time.sleep(0.05)


@contextlib.contextmanager
def alt_screen(enabled: bool) -> Iterator[None]:
    if not enabled:
        yield
        return
    sys.stdout.write("\033[?1049h\033[?25l")
    sys.stdout.flush()
    try:
        yield
    finally:
        sys.stdout.write("\033[?25h\033[?1049l")
        sys.stdout.flush()


def _strip_clear(text: str) -> str:
    return text.replace("\033[H\033[2J", "")


def resolve_for_live(target: str, color: Color) -> tuple[dict[Family, str], DnsResults] | None:
    print_lock = threading.Lock()
    dns_done = threading.Event()
    dns_labels = {source: dns_source_label(source) for source, _, _ in DNS_SOURCES}
    src_w = max(len(label) for label in dns_labels.values())

    def on_dns_result(source: str, family: Family, addr: str | None, err: str) -> None:
        if dns_done.is_set():
            return
        text = color.cyan(addr) if addr else color.red(err or "failed")
        with print_lock:
            if dns_done.is_set():
                return
            print(f"  {dns_labels[source].ljust(src_w)}  {family}: {text}", flush=True)

    try:
        resolved, dns_results = _resolve(target, on_result=on_dns_result)
    finally:
        with print_lock:
            dns_done.set()
    if not resolved:
        print(f"netcheck: Could not resolve target {target}", file=sys.stderr)
        for (source, family), (addr, err) in dns_results.items():
            print(f"  {dns_labels[source]} {family}: {addr or err or '-'}", file=sys.stderr)
        return None
    return resolved, dns_results


def run_live(args: argparse.Namespace, color: Color) -> int:
    # Execution phases:
    # 1. Resolve the target and start the main mtr stream for each family.
    # 2. While mtr is running, update trace/loss from mtr output and start MTU
    #    discovery per family once the target hop has enough main probes.
    # 3. After mtr exits, drain remaining annotation jobs while showing the
    #    task list. The final render is printed outside the alternate screen.
    mtr_prefix = _mtr_command_prefix(args)
    cmd = _build_mtr_cmd(mtr_prefix, args, "-l")
    tailscale_status = tailscale_dns_status(color)
    if tailscale_status:
        print(tailscale_status, flush=True)
    print(f"{color.bold('resolving')} {args.target} ...", flush=True)
    resolved_display = resolve_for_live(args.target, color)
    if resolved_display is None:
        return 1
    resolved, dns_results = resolved_display

    use_alt_screen = color.enabled and sys.stdout.isatty()
    executor = ThreadPoolExecutor(max_workers=8)
    live: LiveRun | None = None
    procs: list[subprocess.Popen[str]] = []
    try:
        live = LiveRun(args=args, color=color, executor=executor, mtr_prefix=mtr_prefix, dns_results=dns_results)
        with alt_screen(use_alt_screen):
            live.start(resolved)
            procs = live.run_mtr(cmd, resolved)
            live.start_mtu_checks(resolved)
            live.drain_jobs(resolved)
    except KeyboardInterrupt:
        _STOP_EVENT.set()
        if live is not None:
            for hop in live.state.hops.values():
                hop.note_losses()
            live.clear = False
            live.render(phase="interrupted")
        sys.stdout.flush()
        executor.shutdown(wait=False, cancel_futures=True)
        os._exit(130)
    else:
        executor.shutdown(wait=True)

    returncode, stderr = _mtr_return_status(procs)

    for hop in live.state.hops.values():
        hop.note_losses()
    if use_alt_screen:
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            live.render(done=True)
        sys.stdout.write(_strip_clear(buf.getvalue()))
        sys.stdout.flush()
    else:
        live.render(done=True)
    if returncode != 0:
        if stderr:
            print(f"mtr: {stderr.strip()}", file=sys.stderr)
        return returncode
    return 0


def main() -> int:
    args = parse_args()
    try:
        return run_live(args, Color(use_color(args.color)))
    except KeyboardInterrupt:
        return 130
    except RuntimeError as exc:
        print(f"netcheck: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
